<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Portfolio of Mousa Amiri - Full-Stack .NET Developer" />
    <title>@ViewData["Title"] - Portfolio</title>
    <link rel="stylesheet" href="~/css/tokens.css" />
    <link rel="stylesheet" href="~/css/base.css" />
    <link rel="stylesheet" href="~/css/layout.css" />
    <link rel="stylesheet" href="~/css/components.css" />
    <link rel="stylesheet" href="~/css/rtl.css" />
</head>
<body>
    <nav class="site-nav" aria-label="Main navigation">
        <div class="container nav-inner">
            <a href="/" class="nav-brand">Mousa Amiri</a>
            <ul class="nav-links">
                <li><a href="#projects">Projects</a></li>
                <li><a href="#skills">Skills</a></li>
                <li><a href="#experience">Experience</a></li>
                <li><a href="#education">Education</a></li>
            </ul>
            <div class="nav-controls">
                <button id="lang-toggle" class="lang-toggle" type="button" aria-label="Switch to Farsi">FA</button>
                <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Switch to dark mode">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
                </button>
            </div>
        </div>
    </nav>

    @RenderBody()

    <footer id="contact" class="site-footer">
        <div class="container">
            <p class="footer-text">&copy; @DateTime.Now.Year Mousa Amiri. All rights reserved.</p>
        </div>
    </footer>

    <script src="~/js/site.js"></script>
</body>
</html>
