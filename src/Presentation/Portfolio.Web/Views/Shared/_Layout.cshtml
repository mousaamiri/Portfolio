@*
    _Layout.cshtml — shared shell for all PUBLIC pages
    ---------------------------------------------------------------------------
    Ported from the static site's per-page shell (PROJECT_CONTEXT.md §1).
    The navbar, footer, command palette, accent-color picker and scroll-progress
    button are all built CLIENT-SIDE by their component scripts (navbar builds
    into #navbar; footer/palette/accent inject into <body>) — this is faithful
    to the source, which ships empty placeholders and hydrates them with JS.
    Routing is wired for MVC via window.__navConfig.routes (migration decision
    #1: SPA-router ported onto MVC routes; #page-content == @RenderBody()).

    Login / Forgot-Password use their OWN minimal layout (Layout = null) — they
    must NOT inherit this shell (AI_PROJECT_RULES.md).
*@
<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="@(ViewData["Description"] ?? "Portfolio of Mousa Amiri Motlagh — Backend Engineer")" />
    <link rel="icon" type="image/svg+xml" href="~/images/favicon.svg" />
    <title>@ViewData["Title"] — Portfolio</title>

    @* ── FOUC-prevention: set theme/dir/lang BEFORE paint (byte-for-byte from source) ── *@
    <script>
        (function(){var t;try{t=localStorage.getItem('portfolio-theme')}catch(e){}if(!t)t=matchMedia('(prefers-color-scheme:light)').matches?'light':'dark';document.documentElement.setAttribute('data-theme',t);var l;try{l=localStorage.getItem('portfolio-lang')}catch(e){}if(l==='fa'){document.documentElement.setAttribute('dir','rtl');document.documentElement.setAttribute('lang','fa')}})();
    </script>

    @* ── Latin webfonts (Farsi AzarMehr/Pinar are self-hosted via @@font-face in tokens.css) ── *@
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@@400;500;600;700;800&family=Instrument+Serif:ital@@1&family=JetBrains+Mono:wght@@400;500;700&display=swap" rel="stylesheet" />

    @* ── Design system: centralized tokens → base → layout → components → shell ── *@
    <link rel="stylesheet" href="~/css/tokens.css" />
    <link rel="stylesheet" href="~/css/base.css" />
    <link rel="stylesheet" href="~/css/layout.css" />
    <link rel="stylesheet" href="~/css/components.css" />
    <link rel="stylesheet" href="~/css/navbar.css" />
    <link rel="stylesheet" href="~/css/footer.css" />
    <link rel="stylesheet" href="~/css/theme-switcher.css" />
    <link rel="stylesheet" href="~/css/spa-transitions.css" />
    @* rtl.css last so [dir="rtl"] overrides win *@
    <link rel="stylesheet" href="~/css/rtl.css" />

    @RenderSection("Styles", required: false)
</head>
<body data-i18n-title="@(ViewData["I18nTitle"] ?? "")">

    @* Navbar placeholder — hydrated by navbar-component.js *@
    <partial name="_Navigation" />

    <main id="page-content">
        @RenderBody()
    </main>

    @* Footer, command palette, accent picker & scroll-progress button are injected
       into <body> by their component scripts below (faithful to the static site). *@

    @* ── GSAP (shared by text-reveal.js and page animations, site-wide as in source) ── *@
    <script src="https://cdn.jsdelivr.net/npm/gsap@@3.13/dist/gsap.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/gsap@@3.13/dist/ScrollTrigger.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/gsap@@3.13/dist/SplitText.min.js"></script>

    @* ── Shell config: MVC routes + current page for the ported navbar/router ── *@
    <script>
        window.__navConfig = {
            currentPage: '@(ViewData["ActivePage"] ?? "home")',
            routes: {
                home:       '@(Url.Action("Index", "Home") ?? "/")',
                about:      '@(Url.Action("Index", "About") ?? "/About")',
                experience: '@(Url.Action("Index", "Experience") ?? "/Experience")',
                work:       '@(Url.Action("Index", "Work") ?? "/Work")',
                blog:       '@(Url.Action("Index", "Blog") ?? "/Blog")',
                contact:    '@(Url.Action("Index", "Contact") ?? "/Contact")'
            }
        };
    </script>

    @* ── Shared shell scripts, in the exact source order. Page-specific scripts
         load in the PageScripts section BETWEEN text-reveal and navbar (matches
         the static site's <script src="home.js"> position — init timing intact). ── *@
    <script src="~/js/translations.js"></script>
    <script src="~/js/i18n.js"></script>
    <script src="~/js/navbar-component.js"></script>
    <script src="~/js/text-reveal.js"></script>

    @RenderSection("PageScripts", required: false)

    <script src="~/js/navbar.js"></script>
    <script src="~/js/command-palette.js"></script>
    <script src="~/js/footer-component.js"></script>
    <script src="~/js/theme-switcher.js"></script>
    <script>
        if (window.i18n) { window.i18n.translateElements(); window.i18n.updateLangSwitcher(); }
    </script>
    <script src="~/js/spa-router.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>
