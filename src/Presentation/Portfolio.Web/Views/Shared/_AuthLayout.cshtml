@*
    _AuthLayout.cshtml — minimal standalone layout for the PUBLIC Login /
    Forgot-Password pages (migration decision #4). These pages are NOT in the
    nav/footer and load NO shell (no navbar, footer, command palette, accent
    picker, or SPA router) — only tokens/base/rtl CSS + fonts + FOUC + the
    client-side i18n runtime. Their forms are pure client-side simulations.
*@
@inject Portfolio.Web.Localization.LocalizationState Loc
@{
    var uiJson = System.Text.Json.JsonSerializer.Serialize(Loc.Map);
}
<!DOCTYPE html>
<html lang="@Loc.Language" dir="@Loc.Dir">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="~/images/favicon.svg" />
    <title>@Html.T((string)(ViewData["I18nTitle"] ?? ""), $"{ViewData["Title"]} — Portfolio")</title>

    @* FOUC-prevention: theme before paint. Language/dir are server-rendered on <html>. *@
    <script>
        (function(){var t;try{t=localStorage.getItem('portfolio-theme')}catch(e){}if(!t)t=matchMedia('(prefers-color-scheme:light)').matches?'light':'dark';document.documentElement.setAttribute('data-theme',t)})();
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@@400;500;600;700;800&family=Instrument+Serif:ital@@1&family=JetBrains+Mono:wght@@400;500;700&display=swap" rel="stylesheet" />

    @* Design tokens + base (identity) + page CSS + RTL — no shell CSS. *@
    <link rel="stylesheet" href="~/css/tokens.css" />
    <link rel="stylesheet" href="~/css/base.css" />
    @RenderSection("Styles", required: false)
    <link rel="stylesheet" href="~/css/rtl.css" />
</head>
<body>

    <script>
        window.__lang = '@Loc.Language';
        window.__ui = @Html.Raw(uiJson);
    </script>

    <main id="page-content">
        @RenderBody()
    </main>

    @* Minimal scripts: server-backed i18n shim + the page's own simulated-form
       script. Localization is server-side (window.__ui + inline defaults). *@
    <script src="~/js/i18n.js"></script>
    @RenderSection("PageScripts", required: false)
</body>
</html>
