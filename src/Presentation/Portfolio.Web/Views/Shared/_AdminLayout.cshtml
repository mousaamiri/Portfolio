@*
    _AdminLayout.cshtml — admin panel shell (dashboard + CRUD screens).
    Phase 3: the panel is now real server-side MVC. Each screen is a server-rendered
    Razor view backed by AdminController, which proxies the authenticated api/admin/*
    endpoints (JWT carried in the auth cookie). shared.js only builds the sidebar,
    theme toggle and mobile nav — the in-memory AdminData store (data.js) was retired.
    Authentication is a real cookie-based sign-in ([Authorize] on AdminController).
*@
<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="~/images/favicon.svg" />
    <title>Admin — @ViewData["AdminTitle"]</title>

    @* Theme bootstrap (admin is English/LTR; only sets data-theme) *@
    <script>
        (function(){var t;try{t=localStorage.getItem('portfolio-theme')}catch(e){}if(!t)t=matchMedia('(prefers-color-scheme:light)').matches?'light':'dark';document.documentElement.setAttribute('data-theme',t)})();
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@@400;500;600;700;800&family=JetBrains+Mono:wght@@400;500;700&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/tokens.css" />
    <link rel="stylesheet" href="~/css/base.css" />
    <link rel="stylesheet" href="~/css/admin/admin.css" />

    <script src="https://unpkg.com/lucide@@latest/dist/umd/lucide.js"></script>
</head>
<body>

    <aside class="admin-sidebar" id="adminSidebar"></aside>
    <div class="admin-sidebar-overlay" id="sidebarOverlay"></div>

    <div class="admin-main">
        <header class="admin-header">
            <button class="admin-hamburger" id="hamburgerBtn" aria-label="Toggle sidebar">
                <i data-lucide="menu"></i>
            </button>
            <span class="admin-header-title">@ViewData["AdminTitle"]</span>
            <div class="admin-header-right"></div>
        </header>
        <main class="admin-content" id="crudContent">@RenderBody()</main>
    </div>

    <div id="toastContainer" class="admin-toast-container"></div>
    <div id="modalOverlay" class="admin-modal-overlay"><div class="admin-modal" id="modalContent"></div></div>

    @* Real server-side logout (Phase 3): clears the admin auth cookie. shared.js's
       logout button submits this antiforgery-protected form. *@
    <form id="logoutForm" asp-controller="Admin" asp-action="Logout" method="post" hidden></form>

    <script src="~/js/admin/shared.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
