@*
    _ClosingCta.cshtml — shared "Closing CTA" block
    ---------------------------------------------------------------------------
    Appears at the bottom of About / Experience / Work / Contact in the static
    site with identical markup. Styles live in footer.css. Static editorial copy
    with data-i18n keys (cta.*); internal links use MVC tag helpers.
*@
<div class="closing-cta-block">
    <div class="closing-cta-eyebrow-row">
        <span class="eyebrow" data-i18n="cta.inner_mechanics">INNER MECHANICS</span>
    </div>
    <h2 class="closing-cta-heading" data-i18n="cta.heading">
        Where logic meets<br />
        <span class="script-gradient">rhythm.</span>
    </h2>

    <div class="closing-cta-grid">
        <div class="closing-cta-card">
            <span class="eyebrow eyebrow--sm" data-i18n="cta.projects">PROJECTS</span>
            <h4 class="closing-cta-card-title" data-i18n="cta.resumeiq">Vitastic</h4>
            <p class="closing-cta-card-desc" data-i18n="cta.resumeiq_desc">Online Learning Platform (DDD / .NET)</p>
            <a asp-controller="Work" asp-action="Index" class="closing-cta-link"><span data-i18n="cta.view_work">View Work</span> <span class="closing-cta-link-arrow">&rarr;</span></a>
        </div>
        <div class="closing-cta-card">
            <span class="eyebrow eyebrow--sm" data-i18n="cta.writing">WRITING</span>
            <h4 class="closing-cta-card-title" data-i18n="cta.article_title">Clean Architecture in ASP.NET Core: Boundaries that Scale</h4>
            <span class="closing-cta-meta" data-i18n="cta.published_date">Draft</span>
            <a asp-controller="Blog" asp-action="Index" class="closing-cta-link"><span data-i18n="cta.read_article">Read Article</span> <span class="closing-cta-link-arrow">&rarr;</span></a>
        </div>
        <div class="closing-cta-card">
            <span class="eyebrow eyebrow--sm" data-i18n="cta.network">NETWORK</span>
            <h4 class="closing-cta-card-title closing-cta-card-title--large" data-i18n="cta.network_title">
                Let's build<br /><span class="script-gradient">together</span>
            </h4>
            <p class="closing-cta-card-desc" data-i18n="cta.collab_desc">Reach out for collaborations or just to say hi.</p>
            <a asp-controller="Contact" asp-action="Index" class="closing-cta-link"><span data-i18n="cta.connect">Connect</span> <span class="closing-cta-link-arrow">&rarr;</span></a>
        </div>
    </div>
</div>
