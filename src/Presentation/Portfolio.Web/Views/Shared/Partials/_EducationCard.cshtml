@model EducationViewModel

<article class="timeline-item">
    <div class="timeline-dot"></div>
    <div class="timeline-content card">
        <div class="timeline-header">
            <h3 class="card-title">@Model.Degree &mdash; @Model.FieldOfStudy</h3>
            <span class="timeline-company">@Model.InstitutionName</span>
        </div>
        <div class="timeline-meta">
            <span class="timeline-date">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                @Model.StartDate.ToString("MMM yyyy") &mdash; @(Model.EndDate?.ToString("MMM yyyy") ?? "Present")
            </span>
            @if (Model.Gpa.HasValue)
            {
                <span class="timeline-gpa">
                    GPA: @Model.Gpa.Value.ToString("F1")
                </span>
            }
        </div>
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p class="card-text">@Model.Description</p>
        }
    </div>
</article>
