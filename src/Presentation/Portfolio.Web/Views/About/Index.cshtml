@model AboutViewModel
@{
    ViewData["Title"] = "About";
    ViewData["I18nTitle"] = "about.title";
    ViewData["ActivePage"] = "about";

    // Skill category → (i18n key, bullet color modifier) — presentation mapping.
    var skillMeta = new Dictionary<string, (string Key, string Color)>
    {
        ["Backend"] = ("about.skills_backend", "amber"),
        ["Frontend"] = ("about.skills_frontend", "pink"),
        ["Database"] = ("about.skills_database", "blue"),
        ["Tools"] = ("about.skills_tools", "green")
    };
    var skillOrder = new[] { "Backend", "Frontend", "Database", "Tools" };
}

@section Styles {
    @* Devicon (About-only CDN) — deferred load + noscript fallback, faithful to source *@
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="preconnect" href="https://unpkg.com" crossorigin />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/devicons/devicon@@latest/devicon.min.css" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/devicons/devicon@@latest/devicon.min.css" /></noscript>
    <link rel="stylesheet" href="~/css/pages/about.css" />
}

@* ======================================================
   TODO: About page (9 sections) — currently from MockDataService
   Model: AboutViewModel (+ TimelineEntry/StatCounter/Interest/Endorsement/Skill/Education VMs)
   Future: will be replaced by a real data source (out of scope for now)
   Note: text stays English-in-markup with data-i18n keys; translations.js → Farsi.
   ====================================================== *@
<section id="about" class="about-section">
    <div class="container">

        @* ===== SECTION 1: HEADER ===== *@
        <div class="about-eyebrow-row">
            <span class="eyebrow">@Html.T("about.eyebrow", "ABOUT")</span>
            <span class="eyebrow-rule" aria-hidden="true"></span>
        </div>
        <h2 class="about-heading">@Html.T("about.heading", "THE ENGINEER BEHIND THE CODE")</h2>

        @* ===== SECTION 2: BIO ROW ===== *@
        <div class="bio-row">
            <div class="bio-photo-col">
                <div class="bio-photo-frame">
                    <img class="bio-photo" src="@Model.PortraitUrl" alt="@Model.PortraitAlt" width="400" height="500" fetchpriority="high" decoding="async" />
                </div>
            </div>
            <div class="bio-content-col">
                <h3 class="bio-subheading">
                    <span>@Html.T("about.bio_subheading", "Engineering with Purpose.")</span>
                    <span class="accent">@Html.T("about.bio_accent", "Driven by Curiosity.")</span>
                </h3>
                <blockquote class="bio-quote">@Html.T("about.bio_quote", "I believe the best code is the code you can explain to someone who didn't write it.")</blockquote>
                <p class="bio-paragraph">@Html.T("about.bio_p1", "I'm a self-taught <span class=\"highlight\">C#/.NET backend developer</span> who fell for the gap between \"it compiles\" and \"it actually works.\" Years of building side projects — not a classroom — taught me how to think like an engineer.")</p>
                <p class="bio-paragraph">@Html.T("about.bio_p2", "Most of my learning has come from shipping real code: rebuilding tangled logic into <span class=\"highlight\">maintainable services</span>, wiring up data access, and chasing down the difference between code that runs on my machine and code that survives production.")</p>
                <p class="bio-paragraph">@Html.T("about.bio_p3", "Today I focus on <span class=\"highlight\">Clean Architecture</span> and <span class=\"highlight\">DDD</span> with ASP.NET Core — drawn to problems at the intersection of performance and simplicity, the kind of engineering that disappears when it's done right.")</p>

                <div class="bio-stats">
                    <div class="bio-stat">
                        <i data-lucide="briefcase" class="bio-stat-icon"></i>
                        <span class="bio-stat-label">@Html.T("about.stat_role", "ROLE")</span>
                        <span class="bio-stat-value">@Html.T("about.stat_role_value", Model.RoleValue)</span>
                    </div>
                    <div class="bio-stat">
                        <i data-lucide="calendar-clock" class="bio-stat-icon"></i>
                        <span class="bio-stat-label">@Html.T("about.stat_experience", "EXPERIENCE")</span>
                        <span class="bio-stat-value">@Html.T("about.stat_experience_value", Model.ExperienceValue)</span>
                    </div>
                    <div class="bio-stat">
                        <i data-lucide="cake" class="bio-stat-icon"></i>
                        <span class="bio-stat-label">@Html.T("about.stat_age", "AGE")</span>
                        @* Live-updating age (computed in about.js from a fixed birthdate) *@
                        <span class="bio-stat-value bio-stat-value--mono" id="live-age">--</span>
                    </div>
                    <div class="bio-stat">
                        <i data-lucide="graduation-cap" class="bio-stat-icon"></i>
                        <span class="bio-stat-label">@Html.T("about.stat_degree", "DEGREE")</span>
                        <span class="bio-stat-value">@Html.T("about.stat_degree_value", Model.DegreeValue)</span>
                    </div>
                </div>
            </div>
        </div>

        @* ===== SECTION 3: JOURNEY / TIMELINE ===== *@
        @if (Model.Journey.Any())
        {
        <div class="journey-block">
            <div class="about-eyebrow-row">
                <span class="eyebrow">@Html.T("about.journey", "JOURNEY")</span>
                <span class="eyebrow-rule" aria-hidden="true"></span>
            </div>
            <div class="timeline">
                <div class="timeline-line" aria-hidden="true"></div>
                @for (var i = 0; i < Model.Journey.Count; i++)
                {
                    var e = Model.Journey[i];
                    var isRight = i % 2 == 0; // entries 1,3,5 (0-indexed even) render content-first
                    <div class="timeline-entry" data-timeline-item>
                        @if (isRight)
                        {
                            <div class="timeline-content timeline-content--right">
                                <span class="timeline-year-mobile">@e.Year</span>
                                <h4 class="timeline-title">@e.Title</h4>
                                <p class="timeline-desc">@e.Description</p>
                            </div>
                            <div class="timeline-node"><i data-lucide="@e.Icon"></i></div>
                            <div class="timeline-year">@e.Year</div>
                        }
                        else
                        {
                            <div class="timeline-year">@e.Year</div>
                            <div class="timeline-node"><i data-lucide="@e.Icon"></i></div>
                            <div class="timeline-content">
                                <span class="timeline-year-mobile">@e.Year</span>
                                <h4 class="timeline-title">@e.Title</h4>
                                <p class="timeline-desc">@e.Description</p>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
        }

        @* ===== SECTION 4: TECHNICAL FOOTPRINT ===== *@
        @if (Model.Footprint.Any())
        {
        <div class="footprint-block">
            <div class="about-eyebrow-row">
                <span class="eyebrow">@Html.T("about.footprint", "TECHNICAL FOOTPRINT")</span>
                <span class="eyebrow-rule" aria-hidden="true"></span>
            </div>
            <div class="footprint-grid">
                @foreach (var s in Model.Footprint)
                {
                    <div class="footprint-card@(s.HasTip ? " footprint-card--has-tip" : "")">
                        @if (s.HasTip)
                        {
                            <button class="footprint-tip-trigger" type="button" aria-label="@s.TipAriaLabel" data-tooltip="@s.TipText">
                                <i data-lucide="info"></i>
                            </button>
                        }
                        <div class="footprint-icon"><i data-lucide="@s.Icon"></i></div>
                        <div class="footprint-number" data-count-target="@s.CountTarget" data-suffix="@(s.Suffix ?? "")">0</div>
                        <div class="footprint-label">@s.Label</div>
                    </div>
                }
            </div>
        </div>
        }

        @* ===== SECTION 5: SKILLS ===== *@
        @if (Model.Skills.Any())
        {
        <div class="skills-block">
            <div class="about-eyebrow-row">
                <span class="eyebrow">@Html.T("about.skills", "SKILLS")</span>
                <span class="eyebrow-rule" aria-hidden="true"></span>
            </div>
            <div class="skills-grid">
                @foreach (var cat in skillOrder)
                {
                    var meta = skillMeta[cat];
                    <div class="skills-card">
                        <div class="skills-card-title">
                            <span class="skills-bullet skills-bullet--@meta.Color" aria-hidden="true"></span>@Html.T(meta.Key, cat.ToUpper())
                        </div>
                        @foreach (var sk in Model.Skills.Where(x => x.Category == cat))
                        {
                            <div class="skill-row">
                                <div class="skill-row-top">
                                    <span>@sk.Name</span>
                                    <span class="skill-pct">@sk.Proficiency%</span>
                                </div>
                                <div class="skill-bar">
                                    <div class="skill-bar-fill" data-target-width="@sk.Proficiency"></div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
        }

        @* ===== SECTION 6: HANDS-ON ===== (static tech pills) *@
        <div class="handson-block">
            <div class="about-eyebrow-row">
                <span class="eyebrow">@Html.T("about.handson", "HANDS-ON")</span>
                <span class="eyebrow-rule" aria-hidden="true"></span>
            </div>
            <div class="pill-grid">
                <div class="tech-pill"><i class="devicon-git-plain colored"></i><span>Git</span></div>
                <div class="tech-pill"><i class="devicon-csharp-plain colored"></i><span>C#</span></div>
                <div class="tech-pill"><i class="devicon-visualstudio-plain colored"></i><span>Visual Studio</span></div>
                <div class="tech-pill"><i class="devicon-amazonwebservices-plain colored"></i><span>AWS</span></div>
                <div class="tech-pill"><i class="devicon-azure-plain colored"></i><span>Azure</span></div>
                <div class="tech-pill"><i class="devicon-googlecloud-plain colored"></i><span>Google Cloud</span></div>
                <div class="tech-pill"><i class="devicon-dotnetcore-plain colored"></i><span>ASP.NET Core</span></div>
                <div class="tech-pill"><i class="devicon-github-original colored"></i><span>GitHub</span></div>
                <div class="tech-pill"><i class="devicon-python-plain colored"></i><span>Python</span></div>
                <div class="tech-pill"><i class="devicon-react-original colored"></i><span>React</span></div>
                <div class="tech-pill"><i class="devicon-linux-plain colored"></i><span>Linux</span></div>
                <div class="tech-pill"><i class="devicon-docker-plain colored"></i><span>Docker</span></div>
                <div class="tech-pill"><i class="devicon-nuget-original colored"></i><span>NuGet</span></div>
                <div class="tech-pill"><i class="devicon-figma-plain colored"></i><span>Figma</span></div>
            </div>
        </div>

        @* ===== SECTION 7: INTERESTS ===== *@
        @if (Model.Interests.Any())
        {
        <div class="interests-block">
            <div class="about-eyebrow-row">
                <span class="eyebrow">@Html.T("about.interests", "INTERESTS")</span>
                <span class="eyebrow-rule" aria-hidden="true"></span>
            </div>
            <div class="interests-grid">
                @foreach (var it in Model.Interests)
                {
                    <div class="interest-card">
                        <i data-lucide="@it.Icon" class="interest-icon"></i>
                        <span class="interest-label">@it.Label</span>
                    </div>
                }
            </div>
        </div>
        }

        @* ===== SECTION 7b: EDUCATION (public section — migration decision #6) ===== *@
        @if (Model.Education.Any())
        {
        <div class="education-block">
            <div class="about-eyebrow-row">
                <span class="eyebrow">@Html.T("about.education", "EDUCATION")</span>
                <span class="eyebrow-rule" aria-hidden="true"></span>
            </div>
            <div class="education-grid">
                @for (var i = 0; i < Model.Education.Count; i++)
                {
                    var ed = Model.Education[i];
                    var n = i + 1;
                    var years = $"{ed.StartDate:yyyy} — {(ed.EndDate?.ToString("yyyy") ?? "Present")}";
                    <div class="education-card">
                        <div class="education-icon"><i data-lucide="graduation-cap"></i></div>
                        <div class="education-body">
                            <h4 class="education-degree">@ed.Degree — @ed.FieldOfStudy</h4>
                            <span class="education-institution">@ed.InstitutionName</span>
                            <div class="education-meta">
                                <span class="education-years">@years</span>
                                @if (!string.IsNullOrEmpty(ed.Score))
                                {
                                    <span class="education-score">@ed.Score</span>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(ed.Description))
                            {
                                <p class="education-desc">@ed.Description</p>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
        }

        @* ===== SECTION 8: ENDORSEMENTS ===== *@
        @if (Model.Endorsements.Any())
        {
        <div class="endorsements-block">
            <div class="about-eyebrow-row">
                <span class="eyebrow">@Html.T("about.endorsements", "ENDORSEMENTS")</span>
                <span class="eyebrow-rule" aria-hidden="true"></span>
            </div>
            <div class="endorsements-row">
                @foreach (var en in Model.Endorsements)
                {
                    <div class="endorsement-card">
                        <div class="endorsement-quote-mask">
                            <p class="endorsement-quote">@en.Quote</p>
                        </div>
                        <div class="endorsement-person">
                            <div class="endorsement-avatar" style="--avatar-color: @en.AvatarColor">@en.Initials</div>
                            <div>
                                <div class="endorsement-name">@en.Name</div>
                                <div class="endorsement-role">@en.Role</div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
        }

    </div>

    @* ===== SECTION 9: CLOSING CTA (shared partial) ===== *@
    <partial name="Partials/_ClosingCta" />
</section>

@section PageScripts {
    @* Lucide (About-only CDN) — must load before about.js calls createIcons() *@
    <script src="https://unpkg.com/lucide@@latest/dist/umd/lucide.js"></script>
    <script src="~/js/pages/about.js"></script>
    <script src="~/js/pages/about-reveal-init.js"></script>
}
