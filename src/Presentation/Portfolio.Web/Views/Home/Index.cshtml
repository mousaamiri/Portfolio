@model HomeViewModel
@{
    ViewData["Title"] = "Home";
    ViewData["I18nTitle"] = "home.title";
    ViewData["ActivePage"] = "home";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/home.css" />
}

@* ======================================================
   TODO: Home hero — currently from MockDataService
   Model: HomeViewModel (FullName, JobTitle, Bio, resume/social URLs, learning popover)
   Future: will be replaced by a real data source (out of scope for now)
   Note: hero TEXT stays English-in-markup with data-i18n keys; translations.js
         supplies Farsi at runtime (client-side i18n, per AI_PROJECT_RULES.md).
   ====================================================== *@
<section id="hero" class="hero-section">
    <div class="hero-spotlight" aria-hidden="true"></div>
    <div class="hero-halo" aria-hidden="true"></div>
    <div class="container hero-container">

        <p class="hero-overline">
            <span class="hero-overline-text" data-typewriter data-i18n="home.cmd_hint">PRESS CMD+K FOR COMMANDS</span
            ><span class="hero-cursor" aria-hidden="true">▊</span>
        </p>

        <h1 class="hero-headline" data-reveal-headline data-i18n="home.name" style="visibility: hidden;">
            @Model.FullName
        </h1>

        <p class="hero-subheadline" data-reveal-sub data-i18n="home.role" style="visibility: hidden;">
            &gt; @Model.JobTitle
        </p>

        <p class="hero-description" data-reveal-sub data-i18n="home.description" style="visibility: hidden;">
            @Model.Bio
        </p>

        <div class="hero-actions" data-reveal-sub style="visibility: hidden;">
            <a id="resume-download" href="@Model.ResumeUrlEn" class="hero-btn hero-btn--primary" download="resume-en.pdf">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                <span data-i18n="home.download_resume">Download Resume</span>
            </a>
            <a asp-controller="Work" asp-action="Index" class="hero-btn hero-btn--ghost">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
                <span data-i18n="home.view_projects">View Projects</span>
            </a>
            <a asp-controller="Contact" asp-action="Index" class="hero-btn hero-btn--ghost">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                <span data-i18n="home.contact">Contact</span>
            </a>
        </div>

        <div class="hero-socials" data-reveal-sub style="visibility: hidden;">
            <a href="@Model.GitHubUrl" target="_blank" rel="noopener noreferrer" class="hero-social-btn" aria-label="GitHub">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
            </a>
            <a href="@Model.InstagramUrl" target="_blank" rel="noopener noreferrer" class="hero-social-btn" aria-label="Instagram">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
            <a href="@Model.LinkedInUrl" target="_blank" rel="noopener noreferrer" class="hero-social-btn" aria-label="LinkedIn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
        </div>

        <div class="hero-status-wrapper">
            <div class="hero-availability-dot" aria-hidden="true"></div>
            <div class="hero-popover" aria-hidden="true">
                <div class="hero-popover-inner">
                    <div class="hero-popover-header">
                        <span class="hero-popover-badge" data-i18n="home.learning">LEARNING</span>
                        <span class="hero-popover-label" data-i18n="home.latest_note">LATEST NOTE</span>
                    </div>
                    <p class="hero-popover-title" data-i18n="home.learning_title">@Model.LearningTitle</p>
                    <p class="hero-popover-desc" data-i18n="home.learning_desc">@Model.LearningDesc</p>
                    <span class="hero-popover-date" data-i18n="home.learning_date">@Model.LearningDate</span>
                </div>
                <div class="hero-popover-tail" aria-hidden="true"></div>
            </div>
        </div>

    </div>
</section>

@section PageScripts {
    <script src="~/js/pages/home.js"></script>
}
