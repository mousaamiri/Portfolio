@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Login";
    ViewData["I18nTitle"] = "login.title";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/login.css" />
}

@* ======================================================
   Public Login — UI-only showcase (migration decision #4).
   Form is a PURE CLIENT-SIDE SIMULATION (login.js: validate → spinner →
   setTimeout 1800ms → "Login successful! Redirecting..." — no real auth,
   no POST, no redirect). Separate from the admin login gate (Step 10).
   Text via data-i18n keys; translations.js supplies Farsi.
   ====================================================== *@
<section class="login-section">
    <div class="login-bg-gradient" aria-hidden="true"></div>

    <div class="login-card">
        <div class="login-logo">
            <img id="loginLogo" src="~/images/logo-en-dark.svg" alt="Logo" class="login-logo-img" />
        </div>

        <h1 class="login-title">@Html.T("login.heading", "Welcome Back")</h1>
        <p class="login-subtitle">@Html.T("login.subtitle", "Sign in to your account to continue")</p>

        <form class="login-form" id="loginForm" novalidate>
            <div class="login-form-group" id="emailGroup">
                <label class="login-form-label" for="loginEmail">@Html.T("login.email_label", "EMAIL")</label>
                <div class="login-input-wrap">
                    <svg class="login-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                        <rect width="20" height="16" x="2" y="4" rx="2"/>
                        <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                    </svg>
                    <input type="email" id="loginEmail" name="email" class="login-input" placeholder="@Html.TA("login.email_placeholder", "you@@email.com")" required autocomplete="email" />
                </div>
                <span class="login-error" id="emailError" aria-live="polite"></span>
            </div>

            <div class="login-form-group" id="passwordGroup">
                <label class="login-form-label" for="loginPassword">@Html.T("login.password_label", "PASSWORD")</label>
                <div class="login-input-wrap">
                    <svg class="login-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                        <rect width="18" height="11" x="3" y="11" rx="2" ry="2"/>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                    <input type="password" id="loginPassword" name="password" class="login-input login-input--password" placeholder="@Html.TA("login.password_placeholder", "Enter your password")" required autocomplete="current-password" />
                    <button type="button" class="login-toggle-password" id="togglePassword" aria-label="Show password">
                        <svg class="icon-eye" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                            <path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"/>
                            <circle cx="12" cy="12" r="3"/>
                        </svg>
                        <svg class="icon-eye-off" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                            <path d="M10.733 5.076a10.744 10.744 0 0 1 11.205 6.575 1 1 0 0 1 0 .696 10.747 10.747 0 0 1-1.444 2.49"/>
                            <path d="M14.084 14.158a3 3 0 0 1-4.242-4.242"/>
                            <path d="M17.479 17.499a10.75 10.75 0 0 1-15.417-5.151 1 1 0 0 1 0-.696 10.75 10.75 0 0 1 4.446-5.143"/>
                            <path d="m2 2 20 20"/>
                        </svg>
                    </button>
                </div>
                <span class="login-error" id="passwordError" aria-live="polite"></span>
            </div>

            <div class="login-options">
                <label class="login-checkbox-label">
                    <input type="checkbox" id="rememberMe" class="login-checkbox" />
                    <span class="login-checkbox-custom"></span>
                    <span>@Html.T("login.remember_me", "Remember me")</span>
                </label>
                <a asp-controller="ForgotPassword" asp-action="Index" class="login-forgot-link">@Html.T("login.forgot_password", "Forgot password?")</a>
            </div>

            <button type="submit" class="login-submit-btn" id="loginSubmitBtn">
                <span class="login-submit-text">@Html.T("login.sign_in", "Sign In")</span>
                <span class="login-submit-spinner" aria-hidden="true"></span>
                <span class="login-submit-arrow">&rarr;</span>
            </button>

            <div class="login-form-feedback" id="loginFeedback" aria-live="polite"></div>
        </form>
    </div>
</section>

@section PageScripts {
    <script src="~/js/pages/login.js"></script>
}
