@model ExperiencePageViewModel
@{
    ViewData["Title"] = "Experience";
    ViewData["I18nTitle"] = "exp.title";
    ViewData["ActivePage"] = "experience";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/experience.css" />
}

@* ======================================================
   Experience page. Model: ExperiencePageViewModel — populated from Portfolio.API
   (Profile summary + ImpactMetrics/Principles/Proficiency/Experiences).
   NOTE: the Proficiency Matrix is NOT the About skills data — different structure
   (name lists, no percentages), so it is modeled/rendered separately.
   ====================================================== *@
<section id="experience" class="experience-section">
    <div class="container">

        @* ===== SECTION 1: HEADER ===== *@
        <div class="about-eyebrow-row">
            <span class="eyebrow">@Html.T("exp.eyebrow", "EXPERIENCE")</span>
            <span class="eyebrow-rule" aria-hidden="true"></span>
        </div>
        <h2 class="exp-heading">@Html.T("exp.heading", "PROFESSIONAL ENGINEERING JOURNEY")</h2>

        @* ===== SECTION 2: IMPACT METRICS + CORE PRINCIPLES ===== *@
        <div class="exp-impact-row">
            @if (Model.Metrics.Any())
            {
            <div class="exp-metrics-grid">
                @foreach (var m in Model.Metrics)
                {
                    <div class="exp-metric-card">
                        <span class="exp-metric-tag exp-metric-tag--@m.Color">@m.Tag</span>
                        <span class="exp-metric-value">@m.Value</span>
                        <p class="exp-metric-desc">@m.Desc</p>
                    </div>
                }
            </div>
            }

            @if (Model.Principles.Any())
            {
            <div class="exp-principles-card">
                <div class="about-eyebrow-row">
                    <span class="eyebrow eyebrow--sm">@Html.T("exp.principles", "CORE PRINCIPLES")</span>
                    <span class="eyebrow-rule" aria-hidden="true"></span>
                </div>
                <ul class="exp-principles-list">
                    @foreach (var p in Model.Principles)
                    {
                        <li class="exp-principle-item">
                            <span class="exp-principle-bullet" aria-hidden="true"></span>
                            <div>
                                <span class="exp-principle-title">@p.Title</span>
                                <span class="exp-principle-desc">@p.Desc</span>
                            </div>
                        </li>
                    }
                </ul>
            </div>
            }
        </div>

        @* ===== SECTION 3: SUMMARY + EDUCATION + PROFESSIONAL EXPERIENCE ===== *@
        <div class="exp-main-row">
            <div class="exp-left-col">

                @if (!string.IsNullOrWhiteSpace(Model.SummaryText))
                {
                    <div class="exp-summary-block">
                        <div class="about-eyebrow-row">
                            <span class="eyebrow eyebrow--sm">@Html.T("exp.summary", "SUMMARY")</span>
                            <span class="eyebrow-rule" aria-hidden="true"></span>
                        </div>
                        <div class="exp-summary-name">
                            <span class="exp-name-bullet" aria-hidden="true"></span>
                            <span>@Model.SummaryName</span>
                        </div>
                        <p class="exp-summary-text">@Model.SummaryText</p>
                    </div>
                }

                @if (Model.Education.Count > 0)
                {
                    <div class="exp-education-block">
                        <div class="about-eyebrow-row">
                            <span class="eyebrow eyebrow--sm">@Html.T("exp.education", "EDUCATION")</span>
                            <span class="eyebrow-rule" aria-hidden="true"></span>
                        </div>
                        <div class="exp-edu-timeline">
                            @foreach (var ed in Model.Education)
                            {
                                <div class="exp-edu-entry@(ed.IsLast ? " exp-edu-entry--last" : "")">
                                    <div class="exp-edu-node" aria-hidden="true">
                                        <span class="exp-edu-circle"></span>
                                        @if (!ed.IsLast)
                                        {
                                            <span class="exp-edu-line"></span>
                                        }
                                    </div>
                                    <div class="exp-edu-content">
                                        <h4 class="exp-edu-title">@ed.Title</h4>
                                        <span class="exp-edu-year">@ed.Years</span>
                                        <p class="exp-edu-institution">@ed.Institution</p>
                                        <p class="exp-edu-score">@ed.Score</p>
                                        @if (ed.Courses.Count > 0)
                                        {
                                            <div class="exp-edu-courses">
                                                @foreach (var c in ed.Courses)
                                                {
                                                    <span class="exp-edu-course-tag">@c.Text</span>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

            </div>

            <div class="exp-right-col">
                <div class="about-eyebrow-row">
                    <span class="eyebrow eyebrow--sm">@Html.T("exp.professional", "PROFESSIONAL EXPERIENCE")</span>
                    <span class="eyebrow-rule" aria-hidden="true"></span>
                </div>

                @if (Model.ProfessionalHistory.Count > 0)
                {
                    @* Real professional history from Portfolio.API. *@
                    foreach (var job in Model.ProfessionalHistory)
                    {
                        var dateRange = $"{job.StartDate:yyyy} – {(job.EndDate.HasValue ? job.EndDate.Value.ToString("yyyy") : "Present")}";
                        <div class="exp-job-header">
                            <div class="exp-job-title-row">
                                <span class="exp-name-bullet" aria-hidden="true"></span>
                                <h3 class="exp-job-title">@job.JobTitle</h3>
                            </div>
                            <span class="exp-job-date-badge">@dateRange</span>
                        </div>
                        <p class="exp-job-company">@job.CompanyName@(string.IsNullOrWhiteSpace(job.Location) ? "" : $" · {job.Location}")</p>
                        @if (!string.IsNullOrWhiteSpace(job.Description))
                        {
                            <p class="exp-job-desc">@job.Description</p>
                        }
                    }
                }
                else if (!string.IsNullOrWhiteSpace(Model.JobTitle))
                {
                    @* Optional static single-role fallback (only shown if configured). *@
                    <div class="exp-job-header">
                        <div class="exp-job-title-row">
                            <span class="exp-name-bullet" aria-hidden="true"></span>
                            <h3 class="exp-job-title">@Model.JobTitle</h3>
                        </div>
                        <span class="exp-job-date-badge">@Model.JobDate</span>
                    </div>
                    <p class="exp-job-company">@Model.JobCompany</p>

                    <ol class="exp-job-list">
                        @for (var i = 0; i < Model.JobBullets.Count; i++)
                        {
                            var b = Model.JobBullets[i];
                            <li class="exp-job-item">
                                <span class="exp-job-num" aria-hidden="true">@(i + 1)</span>
                                <p>@Html.Raw(b.Text)</p>
                            </li>
                        }
                    </ol>

                    @if (Model.Stack.Count > 0)
                    {
                        <div class="exp-stack-block">
                            <span class="eyebrow eyebrow--sm">@Html.T("exp.stack", "STACK")</span>
                            <div class="exp-stack-pills">
                                @foreach (var pill in Model.Stack)
                                {
                                    <span class="exp-stack-pill">@pill</span>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="exp-job-empty">@Html.T("exp.no_history", "Professional history will appear here soon.")</p>
                }
            </div>
        </div>

        @* ===== SECTION 4: TECHNICAL PROFICIENCY MATRIX ===== *@
        @if (Model.Proficiency.Any())
        {
        <div class="exp-proficiency-block">
            <div class="about-eyebrow-row">
                <span class="eyebrow">@Html.T("exp.proficiency", "TECHNICAL PROFICIENCY MATRIX")</span>
                <span class="eyebrow-rule" aria-hidden="true"></span>
            </div>
            <div class="exp-proficiency-grid">
                @foreach (var pg in Model.Proficiency)
                {
                    <div class="exp-proficiency-card">
                        <div class="exp-proficiency-header">
                            <span class="exp-proficiency-bullet exp-proficiency-bullet--@pg.Color" aria-hidden="true"></span>
                            <h4 class="exp-proficiency-title">@pg.Title</h4>
                        </div>
                        <ul class="exp-proficiency-list">
                            @foreach (var item in pg.Items)
                            {
                                <li>@item</li>
                            }
                        </ul>
                    </div>
                }
            </div>
        </div>
        }

    </div>

    @* ===== SECTION 5: CLOSING CTA (shared partial) ===== *@
    <partial name="Partials/_ClosingCta" />
</section>

@section PageScripts {
    <script src="~/js/pages/experience.js"></script>
}
