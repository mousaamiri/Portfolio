@model Portfolio.Web.Models.Admin.EducationFormModel
@{
    Layout = "_AdminLayout";
    var isEdit = Model.IsEdit;
    ViewData["Title"] = isEdit ? "Admin — Edit Education" : "Admin — New Education";
    ViewData["AdminTitle"] = isEdit ? "Edit Education" : "New Education";
    var action = isEdit ? "EducationEdit" : "EducationCreate";
}
<div class="admin-page-header">
    <div><h1 class="admin-page-title">@(isEdit ? "Edit Education" : "New Education")</h1>
        <p class="admin-page-subtitle">Education history entry</p></div>
    <a asp-controller="Admin" asp-action="Education" class="admin-btn admin-btn--ghost">Back to list</a>
</div>
<form asp-controller="Admin" asp-action="@action" asp-route-id="@Model.Id" method="post" class="admin-form">
    <div asp-validation-summary="ModelOnly" class="admin-form-error"></div>
    @if (isEdit) { <input type="hidden" asp-for="Id" /> }

    <div class="admin-form-row">
        <div class="admin-form-group">
            <label class="admin-form-label" asp-for="StartDate"></label>
            <input class="admin-form-input" asp-for="StartDate" type="date" />
        </div>
        <div class="admin-form-group">
            <label class="admin-form-label" asp-for="EndDate"></label>
            <input class="admin-form-input" asp-for="EndDate" type="date" />
        </div>
        <div class="admin-form-group">
            <label class="admin-form-label" asp-for="Gpa"></label>
            <input class="admin-form-input" asp-for="Gpa" type="number" step="0.01" />
        </div>
    </div>
    <div class="admin-form-row">
        <div class="admin-form-group">
            <label class="admin-form-label" asp-for="InstitutionLogo"></label>
            <input class="admin-form-input" asp-for="InstitutionLogo" />
        </div>
        <div class="admin-form-group">
            <label class="admin-form-label" asp-for="InstitutionUrl"></label>
            <input class="admin-form-input" asp-for="InstitutionUrl" placeholder="https://..." />
        </div>
    </div>

    <h3 class="admin-form-section">English</h3>
    <div class="admin-form-row">
        <div class="admin-form-group">
            <label class="admin-form-label" asp-for="DegreeEn"></label>
            <input class="admin-form-input" asp-for="DegreeEn" />
            <span class="admin-form-error" asp-validation-for="DegreeEn"></span>
        </div>
        <div class="admin-form-group">
            <label class="admin-form-label" asp-for="FieldOfStudyEn"></label>
            <input class="admin-form-input" asp-for="FieldOfStudyEn" />
            <span class="admin-form-error" asp-validation-for="FieldOfStudyEn"></span>
        </div>
    </div>
    <div class="admin-form-group">
        <label class="admin-form-label" asp-for="InstitutionNameEn"></label>
        <input class="admin-form-input" asp-for="InstitutionNameEn" />
        <span class="admin-form-error" asp-validation-for="InstitutionNameEn"></span>
    </div>
    <div class="admin-form-group">
        <label class="admin-form-label" asp-for="DescriptionEn"></label>
        <textarea class="admin-form-textarea" asp-for="DescriptionEn" rows="2"></textarea>
    </div>

    <h3 class="admin-form-section">Persian (optional)</h3>
    <div class="admin-form-row">
        <div class="admin-form-group">
            <label class="admin-form-label" asp-for="DegreeFa"></label>
            <input class="admin-form-input admin-form-input--rtl" asp-for="DegreeFa" dir="rtl" />
        </div>
        <div class="admin-form-group">
            <label class="admin-form-label" asp-for="FieldOfStudyFa"></label>
            <input class="admin-form-input admin-form-input--rtl" asp-for="FieldOfStudyFa" dir="rtl" />
        </div>
    </div>
    <div class="admin-form-group">
        <label class="admin-form-label" asp-for="InstitutionNameFa"></label>
        <input class="admin-form-input admin-form-input--rtl" asp-for="InstitutionNameFa" dir="rtl" />
    </div>
    <div class="admin-form-group">
        <label class="admin-form-label" asp-for="DescriptionFa"></label>
        <textarea class="admin-form-textarea admin-form-input--rtl" asp-for="DescriptionFa" dir="rtl" rows="2"></textarea>
    </div>

    @if (isEdit)
    {
        <div class="admin-form-checks">
            <label class="admin-check"><input type="checkbox" asp-for="IsActive" /> <span>@Html.DisplayNameFor(m => m.IsActive)</span></label>
        </div>
    }
    <div class="admin-form-actions">
        <a asp-controller="Admin" asp-action="Education" class="admin-btn admin-btn--ghost">Cancel</a>
        <button type="submit" class="admin-btn admin-btn--primary">@(isEdit ? "Save changes" : "Create")</button>
    </div>
</form>
@section Scripts { <script>(function(){"use strict";AdminSidebar.init("education");if(window.lucide)lucide.createIcons();})();</script> }
