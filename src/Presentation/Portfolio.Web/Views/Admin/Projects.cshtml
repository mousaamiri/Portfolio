@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Admin — Projects";
    ViewData["AdminTitle"] = "Projects";
}

@section Scripts {
    <script>
        (function () {
            "use strict";
            try { if (sessionStorage.getItem("admin_auth") !== "1") { window.location.replace("/Admin/Login"); return; } } catch (e) {}
            AdminSidebar.init("projects");
            if (window.lucide) lucide.createIcons();

            AdminCRUD.init({
                entityName: "Project",
                title: "Projects",
                subtitle: "Manage your portfolio projects",
                store: AdminData.Projects,
                searchKeys: ["title_en", "title_fa", "subtitle_en", "subtitle_fa"],
                columns: [
                    {
                        label: "Title", key: "title_en",
                        render: function (p) {
                            return '<div><div style="font-weight:600">' + AdminUtil.escapeHtml(p.title_en) + '</div>' +
                                '<div class="admin-cell-sub">' + AdminUtil.escapeHtml(p.title_fa) + '</div></div>';
                        }
                    },
                    {
                        label: "Technologies", key: "techs",
                        render: function (p) {
                            if (!p.techs || !p.techs.length) return '<span style="color:var(--text-faint)">—</span>';
                            var shown = p.techs.slice(0, 3).map(function (t) {
                                return '<span class="admin-tag" style="font-size:11px;padding:2px 7px">' + AdminUtil.escapeHtml(t) + '</span>';
                            }).join('');
                            if (p.techs.length > 3) shown += '<span style="font-size:11px;color:var(--text-faint)">+' + (p.techs.length - 3) + '</span>';
                            return '<div style="display:flex;flex-wrap:wrap;gap:4px">' + shown + '</div>';
                        }
                    },
                    {
                        label: "Status", key: "status",
                        render: function (p) {
                            var cls = p.status === "published" ? "admin-status--published" : "admin-status--draft";
                            var txt = p.status === "published" ? "Published" : "Draft";
                            return '<span class="admin-status ' + cls + '"><span class="admin-status-dot"></span>' + txt + '</span>';
                        }
                    }
                ],
                formFields: [
                    { key: "title", label: "Title", bilingual: true, required: true, placeholder: "Project name" },
                    { key: "subtitle", label: "Short Description", bilingual: true, placeholder: "One-line description" },
                    { key: "description", label: "Full Description", bilingual: true, type: "textarea", rows: 4, placeholder: "Detailed description" },
                    { key: "techs", label: "Technologies", type: "tags", placeholder: "Add technology and press Enter", hint: "Press Enter or comma to add" },
                    { type: "row", fields: [
                        { key: "demoUrl", label: "Demo URL", placeholder: "https://..." },
                        { key: "githubUrl", label: "GitHub URL", placeholder: "https://github.com/..." }
                    ]},
                    { key: "status", label: "Status", type: "select", options: [
                        { value: "published", label: "Published" },
                        { value: "draft", label: "Draft" }
                    ], defaultValue: "published" }
                ]
            });
        })();
    </script>
}
