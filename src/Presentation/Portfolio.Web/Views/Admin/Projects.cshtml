@model List<Portfolio.Web.Models.Admin.ProjectListItem>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Admin — Projects";
    ViewData["AdminTitle"] = "Projects";
}

<div class="admin-page-header">
    <div>
        <h1 class="admin-page-title">Projects</h1>
        <p class="admin-page-subtitle">Manage your portfolio projects</p>
    </div>
    <a asp-controller="Admin" asp-action="ProjectCreate" class="admin-btn admin-btn--primary">
        <i data-lucide="plus"></i><span>New Project</span>
    </a>
</div>

@if (TempData["AdminMessage"] is string msg)
{
    <div class="admin-toast admin-toast--inline" role="status">@msg</div>
}

@if (Model.Count == 0)
{
    <div class="admin-empty">
        <p>No projects yet.</p>
        <a asp-controller="Admin" asp-action="ProjectCreate" class="admin-btn admin-btn--primary admin-btn--sm">Create the first one</a>
    </div>
}
else
{
    <table class="admin-table">
        <thead>
            <tr>
                <th>Title</th>
                <th>Slug</th>
                <th>Technologies</th>
                <th>Status</th>
                <th style="text-align:right">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td style="font-weight:600">@p.Title</td>
                    <td><code>@p.Slug</code></td>
                    <td>
                        @if (string.IsNullOrWhiteSpace(p.Technologies))
                        {
                            <span style="color:var(--text-faint)">—</span>
                        }
                        else
                        {
                            @foreach (var t in p.Technologies.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).Take(3))
                            {
                                <span class="admin-tag" style="font-size:11px;padding:2px 7px">@t</span>
                            }
                        }
                    </td>
                    <td>
                        <span class="admin-status @(p.IsPublished ? "admin-status--published" : "admin-status--draft")">
                            <span class="admin-status-dot"></span>@(p.IsPublished ? "Published" : "Draft")
                        </span>
                    </td>
                    <td style="text-align:right;white-space:nowrap">
                        <a asp-controller="Admin" asp-action="ProjectEdit" asp-route-id="@p.Id" class="admin-btn admin-btn--ghost admin-btn--sm">Edit</a>
                        <form asp-controller="Admin" asp-action="ProjectDelete" asp-route-id="@p.Id" method="post" style="display:inline"
                              onsubmit="return confirm('Delete this project? This cannot be undone.');">
                            <button type="submit" class="admin-btn admin-btn--danger admin-btn--sm">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@section Scripts {
    <script>
        (function () {
            "use strict";
            AdminSidebar.init("projects");
            if (window.lucide) lucide.createIcons();
        })();
    </script>
}
