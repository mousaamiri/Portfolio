@model Portfolio.Web.Models.Admin.TestimonialFormModel
@{
    Layout = "_AdminLayout";
    var isEdit = Model.IsEdit;
    ViewData["Title"] = isEdit ? "Admin — Edit Testimonial" : "Admin — New Testimonial";
    ViewData["AdminTitle"] = isEdit ? "Edit Testimonial" : "New Testimonial";
    var action = isEdit ? "TestimonialEdit" : "TestimonialCreate";
}
<div class="admin-page-header">
    <div><h1 class="admin-page-title">@(isEdit ? "Edit Testimonial" : "New Testimonial")</h1>
        <p class="admin-page-subtitle">About-page endorsement</p></div>
    <a asp-controller="Admin" asp-action="Testimonials" class="admin-btn admin-btn--ghost">Back to list</a>
</div>
<form asp-controller="Admin" asp-action="@action" asp-route-id="@Model.Id" method="post" class="admin-form">
    <div asp-validation-summary="ModelOnly" class="admin-form-error"></div>
    @if (isEdit) { <input type="hidden" asp-for="Id" /> }

    <div class="admin-form-row">
        <div class="admin-form-group">
            <label class="admin-form-label" asp-for="Initials"></label>
            <input class="admin-form-input" asp-for="Initials" placeholder="JD" />
        </div>
        <div class="admin-form-group">
            <label class="admin-form-label" asp-for="AvatarColor"></label>
            <input class="admin-form-input" asp-for="AvatarColor" placeholder="var(--accent) or #ec4899" />
        </div>
        <div class="admin-form-group">
            <label class="admin-form-label" asp-for="DisplayOrder"></label>
            <input class="admin-form-input" asp-for="DisplayOrder" type="number" />
        </div>
    </div>

    <h3 class="admin-form-section">English</h3>
    <div class="admin-form-row">
        <div class="admin-form-group">
            <label class="admin-form-label" asp-for="NameEn"></label>
            <input class="admin-form-input" asp-for="NameEn" />
            <span class="admin-form-error" asp-validation-for="NameEn"></span>
        </div>
        <div class="admin-form-group">
            <label class="admin-form-label" asp-for="RoleEn"></label>
            <input class="admin-form-input" asp-for="RoleEn" />
        </div>
    </div>
    <div class="admin-form-group">
        <label class="admin-form-label" asp-for="QuoteEn"></label>
        <textarea class="admin-form-textarea" asp-for="QuoteEn" rows="3"></textarea>
        <span class="admin-form-error" asp-validation-for="QuoteEn"></span>
    </div>

    <h3 class="admin-form-section">Persian (optional)</h3>
    <div class="admin-form-row">
        <div class="admin-form-group">
            <label class="admin-form-label" asp-for="NameFa"></label>
            <input class="admin-form-input admin-form-input--rtl" asp-for="NameFa" dir="rtl" />
        </div>
        <div class="admin-form-group">
            <label class="admin-form-label" asp-for="RoleFa"></label>
            <input class="admin-form-input admin-form-input--rtl" asp-for="RoleFa" dir="rtl" />
        </div>
    </div>
    <div class="admin-form-group">
        <label class="admin-form-label" asp-for="QuoteFa"></label>
        <textarea class="admin-form-textarea admin-form-input--rtl" asp-for="QuoteFa" dir="rtl" rows="3"></textarea>
    </div>

    @if (isEdit)
    {
        <div class="admin-form-checks">
            <label class="admin-check"><input type="checkbox" asp-for="IsActive" /> <span>@Html.DisplayNameFor(m => m.IsActive)</span></label>
        </div>
    }
    <div class="admin-form-actions">
        <a asp-controller="Admin" asp-action="Testimonials" class="admin-btn admin-btn--ghost">Cancel</a>
        <button type="submit" class="admin-btn admin-btn--primary">@(isEdit ? "Save changes" : "Create")</button>
    </div>
</form>
@section Scripts { <script>(function(){"use strict";AdminSidebar.init("testimonials");if(window.lucide)lucide.createIcons();})();</script> }
