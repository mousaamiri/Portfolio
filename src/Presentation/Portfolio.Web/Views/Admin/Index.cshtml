@model Portfolio.Web.Models.Admin.AdminDashboardViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Admin — Dashboard";
    ViewData["AdminTitle"] = "Dashboard";

    var cards = new[]
    {
        new { Label = "Projects",     Count = Model.Projects,     Icon = "folder-kanban",  Fg = "#f0a63b", Bg = "rgba(240,166,59,0.12)", Href = "/Admin/Projects",     Sub = (string?)null },
        new { Label = "Articles",     Count = Model.Articles,     Icon = "file-text",      Fg = "#3b82f6", Bg = "rgba(59,130,246,0.12)", Href = "/Admin/Articles",     Sub = (string?)null },
        new { Label = "Experiences",  Count = Model.Experiences,  Icon = "briefcase",      Fg = "#22c55e", Bg = "rgba(34,197,94,0.12)",  Href = "/Admin/Experiences",  Sub = (string?)null },
        new { Label = "Education",    Count = Model.Education,     Icon = "graduation-cap", Fg = "#a855f7", Bg = "rgba(168,85,247,0.12)", Href = "/Admin/Education",     Sub = (string?)null },
        new { Label = "Skills",       Count = Model.Skills,       Icon = "star",           Fg = "#14b8a6", Bg = "rgba(20,184,166,0.12)", Href = "/Admin/Skills",       Sub = (string?)null },
        new { Label = "Testimonials", Count = Model.Testimonials, Icon = "quote",          Fg = "#ec4899", Bg = "rgba(236,72,153,0.12)", Href = "/Admin/Testimonials", Sub = (string?)null },
        new { Label = "Messages",     Count = Model.Messages,     Icon = "mail",           Fg = "#ef4444", Bg = "rgba(239,68,68,0.12)",  Href = "/Admin/Messages",     Sub = (string?)(Model.UnreadMessages + " unread") },
    };
}

<div class="admin-page-header">
    <div>
        <h1 class="admin-page-title">Dashboard</h1>
        <p class="admin-page-subtitle">Overview of your portfolio content</p>
    </div>
</div>

<div class="admin-stats-grid">
    @foreach (var c in cards)
    {
        <a href="@c.Href" class="admin-stat-card">
            <div class="admin-stat-header">
                <span class="admin-stat-label">@c.Label</span>
                <div class="admin-stat-icon" style="background:@c.Bg;color:@c.Fg"><i data-lucide="@c.Icon"></i></div>
            </div>
            <div class="admin-stat-value">@c.Count</div>
            @if (c.Sub is not null)
            {
                <div class="admin-stat-sub">@c.Sub</div>
            }
        </a>
    }
</div>

@section Scripts {
    <script>
        (function () {
            "use strict";
            AdminSidebar.init("index");
            if (window.lucide) lucide.createIcons();
        })();
    </script>
}
