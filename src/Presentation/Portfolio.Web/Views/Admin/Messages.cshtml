@model List<Portfolio.Web.Services.Api.MessageApiDto>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Admin — Messages";
    ViewData["AdminTitle"] = "Messages";
}
<div class="admin-page-header">
    <div><h1 class="admin-page-title">Messages</h1>
        <p class="admin-page-subtitle">Contact-form submissions</p></div>
</div>
@if (TempData["AdminMessage"] is string msg)
{
    <div class="admin-toast admin-toast--inline" role="status">@msg</div>
}
@if (Model.Count == 0)
{
    <div class="admin-empty"><p>No messages yet.</p></div>
}
else
{
    <table class="admin-table">
        <thead>
            <tr><th>From</th><th>Subject</th><th>Received</th><th>Status</th><th style="text-align:right">Actions</th></tr>
        </thead>
        <tbody>
            @foreach (var m in Model.OrderByDescending(x => x.CreatedAt))
            {
                <tr style="@(m.IsRead ? "" : "font-weight:600")">
                    <td class="admin-cell-strong">@m.Name<div class="admin-cell-sub" style="font-weight:400">@m.Email</div></td>
                    <td>@(string.IsNullOrWhiteSpace(m.Subject) ? "—" : m.Subject)</td>
                    <td>@m.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>
                        <span class="admin-status @(m.IsRead ? "admin-status--draft" : "admin-status--published")">
                            <span class="admin-status-dot"></span>@(m.IsRead ? "Read" : "Unread")
                        </span>
                    </td>
                    <td style="text-align:right;white-space:nowrap">
                        <a asp-controller="Admin" asp-action="MessageView" asp-route-id="@m.Id" class="admin-btn admin-btn--ghost admin-btn--sm">View</a>
                        <form asp-controller="Admin" asp-action="MessageDelete" asp-route-id="@m.Id" method="post" style="display:inline"
                              onsubmit="return confirm('Delete this message?');">
                            <button type="submit" class="admin-btn admin-btn--danger admin-btn--sm">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
@section Scripts { <script>(function(){"use strict";AdminSidebar.init("messages");if(window.lucide)lucide.createIcons();})();</script> }
