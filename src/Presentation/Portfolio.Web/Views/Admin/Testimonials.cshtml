@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Admin — Testimonials";
    ViewData["AdminTitle"] = "Testimonials";
}

@section Scripts {
    <script>
        (function () {
            "use strict";
            try { if (sessionStorage.getItem("admin_auth") !== "1") { window.location.replace("/Admin/Login"); return; } } catch (e) {}
            AdminSidebar.init("testimonials");
            if (window.lucide) lucide.createIcons();

            AdminCRUD.init({
                entityName: "Testimonial",
                title: "Testimonials",
                subtitle: "Manage client testimonials",
                store: AdminData.Testimonials,
                searchKeys: ["name_en", "name_fa", "role_en", "role_fa", "quote_en", "quote_fa"],
                columns: [
                    {
                        label: "Name", key: "name_en",
                        render: function (t) {
                            return '<div><div style="font-weight:600">' + AdminUtil.escapeHtml(t.name_en) + '</div>' +
                                '<div class="admin-cell-sub">' + AdminUtil.escapeHtml(t.name_fa) + '</div></div>';
                        }
                    },
                    {
                        label: "Role", key: "role_en",
                        render: function (t) {
                            return '<div><div>' + AdminUtil.escapeHtml(t.role_en) + '</div>' +
                                '<div class="admin-cell-sub">' + AdminUtil.escapeHtml(t.role_fa) + '</div></div>';
                        }
                    },
                    {
                        label: "Quote", key: "quote_en",
                        render: function (t) {
                            return '<div style="max-width:300px"><div style="font-size:13px;color:var(--text-muted)">"' +
                                AdminUtil.escapeHtml(AdminUtil.truncate(t.quote_en, 80)) + '"</div></div>';
                        }
                    }
                ],
                formFields: [
                    { key: "name", label: "Name", bilingual: true, required: true, placeholder: "Full name" },
                    { key: "role", label: "Role / Position", bilingual: true, placeholder: "e.g. CTO at Company" },
                    { key: "quote", label: "Quote", bilingual: true, type: "textarea", rows: 4, required: true, placeholder: "Testimonial text" }
                ]
            });
        })();
    </script>
}
