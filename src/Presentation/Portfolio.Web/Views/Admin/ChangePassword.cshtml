@model Portfolio.Web.Models.Admin.ChangePasswordFormModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Admin — Change Password";
    ViewData["AdminTitle"] = "Change Password";
}

<div class="admin-page-header">
    <div>
        <h1 class="admin-page-title">Change Password</h1>
        <p class="admin-page-subtitle">Update your admin account password</p>
    </div>
    <a asp-controller="Admin" asp-action="Index" class="admin-btn admin-btn--ghost">Back to dashboard</a>
</div>

<form asp-controller="Admin" asp-action="ChangePassword" method="post" class="admin-form" style="max-width:520px">
    <div asp-validation-summary="ModelOnly" class="admin-form-error"></div>

    <div class="admin-form-group">
        <label class="admin-form-label" asp-for="CurrentPassword"></label>
        <input class="admin-form-input" asp-for="CurrentPassword" type="password" autocomplete="current-password" />
        <span class="admin-form-error" asp-validation-for="CurrentPassword"></span>
    </div>
    <div class="admin-form-group">
        <label class="admin-form-label" asp-for="NewPassword"></label>
        <input class="admin-form-input" asp-for="NewPassword" type="password" autocomplete="new-password" />
        <span class="admin-form-hint">At least 8 characters.</span>
        <span class="admin-form-error" asp-validation-for="NewPassword"></span>
    </div>
    <div class="admin-form-group">
        <label class="admin-form-label" asp-for="ConfirmPassword"></label>
        <input class="admin-form-input" asp-for="ConfirmPassword" type="password" autocomplete="new-password" />
        <span class="admin-form-error" asp-validation-for="ConfirmPassword"></span>
    </div>

    <div class="admin-form-actions">
        <a asp-controller="Admin" asp-action="Index" class="admin-btn admin-btn--ghost">Cancel</a>
        <button type="submit" class="admin-btn admin-btn--primary">Change password</button>
    </div>
</form>

@section Scripts {
    <script>(function(){"use strict";AdminSidebar.init("");if(window.lucide)lucide.createIcons();})();</script>
}
