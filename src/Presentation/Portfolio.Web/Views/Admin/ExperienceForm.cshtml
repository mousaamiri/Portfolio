@model Portfolio.Web.Models.Admin.ExperienceFormModel
@{
    Layout = "_AdminLayout";
    var isEdit = Model.IsEdit;
    ViewData["Title"] = isEdit ? "Admin — Edit Experience" : "Admin — New Experience";
    ViewData["AdminTitle"] = isEdit ? "Edit Experience" : "New Experience";
    var action = isEdit ? "ExperienceEdit" : "ExperienceCreate";
}
<div class="admin-page-header">
    <div><h1 class="admin-page-title">@(isEdit ? "Edit Experience" : "New Experience")</h1>
        <p class="admin-page-subtitle">Professional history entry</p></div>
    <a asp-controller="Admin" asp-action="Experiences" class="admin-btn admin-btn--ghost">Back to list</a>
</div>
<form asp-controller="Admin" asp-action="@action" asp-route-id="@Model.Id" method="post" class="admin-form">
    <div asp-validation-summary="ModelOnly" class="admin-form-error"></div>
    @if (isEdit) { <input type="hidden" asp-for="Id" /> }

    <div class="admin-form-row">
        <div class="admin-form-group">
            <label class="admin-form-label" asp-for="StartDate"></label>
            <input class="admin-form-input" asp-for="StartDate" type="date" />
        </div>
        <div class="admin-form-group">
            <label class="admin-form-label" asp-for="EndDate"></label>
            <input class="admin-form-input" asp-for="EndDate" type="date" />
            <span class="admin-form-hint">Leave empty if current.</span>
        </div>
    </div>
    <div class="admin-form-row">
        <div class="admin-form-group">
            <label class="admin-form-label" asp-for="CompanyLogo"></label>
            <input class="admin-form-input" asp-for="CompanyLogo" />
        </div>
        <div class="admin-form-group">
            <label class="admin-form-label" asp-for="CompanyUrl"></label>
            <input class="admin-form-input" asp-for="CompanyUrl" placeholder="https://..." />
        </div>
    </div>

    <h3 class="admin-form-section">English</h3>
    <div class="admin-form-row">
        <div class="admin-form-group">
            <label class="admin-form-label" asp-for="JobTitleEn"></label>
            <input class="admin-form-input" asp-for="JobTitleEn" />
            <span class="admin-form-error" asp-validation-for="JobTitleEn"></span>
        </div>
        <div class="admin-form-group">
            <label class="admin-form-label" asp-for="CompanyNameEn"></label>
            <input class="admin-form-input" asp-for="CompanyNameEn" />
            <span class="admin-form-error" asp-validation-for="CompanyNameEn"></span>
        </div>
    </div>
    <div class="admin-form-group">
        <label class="admin-form-label" asp-for="LocationEn"></label>
        <input class="admin-form-input" asp-for="LocationEn" />
    </div>
    <div class="admin-form-group">
        <label class="admin-form-label" asp-for="DescriptionEn"></label>
        <textarea class="admin-form-textarea" asp-for="DescriptionEn" rows="3"></textarea>
    </div>

    <h3 class="admin-form-section">Persian (optional)</h3>
    <div class="admin-form-row">
        <div class="admin-form-group">
            <label class="admin-form-label" asp-for="JobTitleFa"></label>
            <input class="admin-form-input admin-form-input--rtl" asp-for="JobTitleFa" dir="rtl" />
        </div>
        <div class="admin-form-group">
            <label class="admin-form-label" asp-for="CompanyNameFa"></label>
            <input class="admin-form-input admin-form-input--rtl" asp-for="CompanyNameFa" dir="rtl" />
        </div>
    </div>
    <div class="admin-form-group">
        <label class="admin-form-label" asp-for="LocationFa"></label>
        <input class="admin-form-input admin-form-input--rtl" asp-for="LocationFa" dir="rtl" />
    </div>
    <div class="admin-form-group">
        <label class="admin-form-label" asp-for="DescriptionFa"></label>
        <textarea class="admin-form-textarea admin-form-input--rtl" asp-for="DescriptionFa" dir="rtl" rows="3"></textarea>
    </div>

    @if (isEdit)
    {
        <div class="admin-form-checks">
            <label class="admin-check"><input type="checkbox" asp-for="IsActive" /> <span>@Html.DisplayNameFor(m => m.IsActive)</span></label>
        </div>
    }
    <div class="admin-form-actions">
        <a asp-controller="Admin" asp-action="Experiences" class="admin-btn admin-btn--ghost">Cancel</a>
        <button type="submit" class="admin-btn admin-btn--primary">@(isEdit ? "Save changes" : "Create")</button>
    </div>
</form>
@section Scripts { <script>(function(){"use strict";AdminSidebar.init("experiences");if(window.lucide)lucide.createIcons();})();</script> }
