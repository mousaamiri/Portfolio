@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Admin — Experiences";
    ViewData["AdminTitle"] = "Experiences";
}

@section Scripts {
    <script>
        (function () {
            "use strict";
            AdminSidebar.init("experiences");
            if (window.lucide) lucide.createIcons();

            AdminCRUD.init({
                entityName: "Experience",
                title: "Experiences",
                subtitle: "Manage your work history",
                store: AdminData.Experiences,
                searchKeys: ["jobTitle_en", "jobTitle_fa", "company_en", "company_fa"],
                columns: [
                    {
                        label: "Job Title", key: "jobTitle_en",
                        render: function (e) {
                            return '<div><div style="font-weight:600">' + AdminUtil.escapeHtml(e.jobTitle_en) + '</div>' +
                                '<div class="admin-cell-sub">' + AdminUtil.escapeHtml(e.jobTitle_fa) + '</div></div>';
                        }
                    },
                    {
                        label: "Company", key: "company_en",
                        render: function (e) {
                            return '<div><div>' + AdminUtil.escapeHtml(e.company_en) + '</div>' +
                                '<div class="admin-cell-sub">' + AdminUtil.escapeHtml(e.company_fa) + '</div></div>';
                        }
                    },
                    {
                        label: "Period", key: "startDate",
                        render: function (e) {
                            var end = e.isCurrent ? '<span style="color:var(--green);font-weight:600">Present</span>' : AdminUtil.escapeHtml(e.endDate);
                            return AdminUtil.escapeHtml(e.startDate) + ' — ' + end;
                        }
                    }
                ],
                formFields: [
                    { key: "jobTitle", label: "Job Title", bilingual: true, required: true, placeholder: "e.g. Senior Developer" },
                    { key: "company", label: "Company", bilingual: true, required: true, placeholder: "e.g. Tech Corp" },
                    { key: "description", label: "Description", bilingual: true, type: "textarea", rows: 4, placeholder: "Describe your responsibilities" },
                    { type: "row", fields: [
                        { key: "startDate", label: "Start Date", placeholder: "YYYY-MM", required: true },
                        { key: "endDate", label: "End Date", placeholder: "YYYY-MM (leave empty if current)" }
                    ]},
                    { key: "isCurrent", label: "Employment Status", type: "checkbox", checkboxLabel: "I currently work here" }
                ]
            });
        })();
    </script>
}
