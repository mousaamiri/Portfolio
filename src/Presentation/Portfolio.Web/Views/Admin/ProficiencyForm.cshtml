@model Portfolio.Web.Models.Admin.ProficiencyFormModel
@{
    Layout = "_AdminLayout";
    var isEdit = Model.IsEdit;
    ViewData["Title"] = isEdit ? "Admin — Edit Proficiency" : "Admin — New Proficiency";
    ViewData["AdminTitle"] = isEdit ? "Edit Proficiency Group" : "New Proficiency Group";
    var action = isEdit ? "ProficiencyEdit" : "ProficiencyCreate";
}
<div class="admin-page-header">
    <div><h1 class="admin-page-title">@(isEdit ? "Edit Proficiency Group" : "New Proficiency Group")</h1>
        <p class="admin-page-subtitle">Experience-page proficiency matrix</p></div>
    <a asp-controller="Admin" asp-action="Proficiencies" class="admin-btn admin-btn--ghost">Back to list</a>
</div>
<form asp-controller="Admin" asp-action="@action" asp-route-id="@Model.Id" method="post" class="admin-form">
    <div asp-validation-summary="ModelOnly" class="admin-form-error"></div>
    @if (isEdit) { <input type="hidden" asp-for="Id" /> }
    <div class="admin-form-row">
        <div class="admin-form-group">
            <label class="admin-form-label" asp-for="Color"></label>
            <input class="admin-form-input" asp-for="Color" placeholder="amber / pink / purple" />
        </div>
        <div class="admin-form-group">
            <label class="admin-form-label" asp-for="DisplayOrder"></label>
            <input class="admin-form-input" asp-for="DisplayOrder" type="number" />
        </div>
    </div>
    <h3 class="admin-form-section">English</h3>
    <div class="admin-form-group">
        <label class="admin-form-label" asp-for="TitleEn"></label>
        <input class="admin-form-input" asp-for="TitleEn" placeholder="MASTERY (CORE STACK)" />
        <span class="admin-form-error" asp-validation-for="TitleEn"></span>
    </div>
    <div class="admin-form-group">
        <label class="admin-form-label" asp-for="ItemsEn"></label>
        <textarea class="admin-form-textarea" asp-for="ItemsEn" rows="2" placeholder="Java 21, Spring Boot, MySQL"></textarea>
    </div>
    <h3 class="admin-form-section">Persian (optional)</h3>
    <div class="admin-form-group">
        <label class="admin-form-label" asp-for="TitleFa"></label>
        <input class="admin-form-input admin-form-input--rtl" asp-for="TitleFa" dir="rtl" />
    </div>
    <div class="admin-form-group">
        <label class="admin-form-label" asp-for="ItemsFa"></label>
        <textarea class="admin-form-textarea admin-form-input--rtl" asp-for="ItemsFa" dir="rtl" rows="2"></textarea>
    </div>
    @if (isEdit)
    {
        <div class="admin-form-checks">
            <label class="admin-check"><input type="checkbox" asp-for="IsActive" /> <span>@Html.DisplayNameFor(m => m.IsActive)</span></label>
        </div>
    }
    <div class="admin-form-actions">
        <a asp-controller="Admin" asp-action="Proficiencies" class="admin-btn admin-btn--ghost">Cancel</a>
        <button type="submit" class="admin-btn admin-btn--primary">@(isEdit ? "Save changes" : "Create")</button>
    </div>
</form>
@section Scripts { <script>(function(){"use strict";AdminSidebar.init("proficiencies");if(window.lucide)lucide.createIcons();})();</script> }
