@{
    Layout = "_AdminAuthLayout";
    ViewData["Title"] = "Forgot Password";
    ViewData["AdminTitle"] = "Forgot Password";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin/forgot-password.css" />
}

@* Honest recovery info — there is no email-based reset in this single-admin app.
   The simulated setTimeout flow was removed in Phase 3. *@
<section class="forgot-section">
    <div class="forgot-bg-gradient" aria-hidden="true"></div>

    <div class="forgot-card">
        <a asp-controller="Admin" asp-action="Login" class="forgot-back-link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                <path d="m15 18-6-6 6-6"/>
            </svg>
            <span>Back to sign in</span>
        </a>

        <h1 class="forgot-title">Password recovery</h1>
        <p class="forgot-subtitle" style="line-height:1.7">
            This portfolio has a single administrator and no email-based reset flow.
            To change your password, sign in and use
            <strong>Change Password</strong> from the sidebar.
        </p>
        <p class="forgot-subtitle" style="line-height:1.7;margin-top:14px">
            If you're locked out entirely, the password can be reset from the server
            by updating the <code>AdminSeed:Password</code> user-secret and reseeding,
            or by updating the admin record directly in the database.
        </p>
    </div>
</section>
