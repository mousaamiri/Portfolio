@model Portfolio.Web.Models.Admin.SkillFormModel
@{
    Layout = "_AdminLayout";
    var isEdit = Model.IsEdit;
    ViewData["Title"] = isEdit ? "Admin — Edit Skill" : "Admin — New Skill";
    ViewData["AdminTitle"] = isEdit ? "Edit Skill" : "New Skill";
    var formAction = isEdit ? "SkillEdit" : "SkillCreate";
}

<div class="admin-page-header">
    <div>
        <h1 class="admin-page-title">@(isEdit ? "Edit Skill" : "New Skill")</h1>
        <p class="admin-page-subtitle">@(isEdit ? Model.NameEn : "Add a skill to your portfolio")</p>
    </div>
    <a asp-controller="Admin" asp-action="Skills" class="admin-btn admin-btn--ghost">Back to list</a>
</div>

<form asp-controller="Admin" asp-action="@formAction" asp-route-id="@Model.Id" method="post" class="admin-form">
    <div asp-validation-summary="ModelOnly" class="admin-form-error"></div>
    @if (isEdit) { <input type="hidden" asp-for="Id" /> }

    <div class="admin-form-row">
        <div class="admin-form-group">
            <label class="admin-form-label" asp-for="IconUrl"></label>
            <input class="admin-form-input" asp-for="IconUrl" placeholder="csharp, docker, git…" />
            <span class="admin-form-hint">devicon name (or leave a short label).</span>
            <span class="admin-form-error" asp-validation-for="IconUrl"></span>
        </div>
        <div class="admin-form-group">
            <label class="admin-form-label" asp-for="Proficiency"></label>
            <input class="admin-form-input" asp-for="Proficiency" type="number" min="0" max="100" />
            <span class="admin-form-error" asp-validation-for="Proficiency"></span>
        </div>
        <div class="admin-form-group">
            <label class="admin-form-label" asp-for="DisplayOrder"></label>
            <input class="admin-form-input" asp-for="DisplayOrder" type="number" />
        </div>
    </div>

    <h3 class="admin-form-section">English</h3>
    <div class="admin-form-row">
        <div class="admin-form-group">
            <label class="admin-form-label" asp-for="NameEn"></label>
            <input class="admin-form-input" asp-for="NameEn" />
            <span class="admin-form-error" asp-validation-for="NameEn"></span>
        </div>
        <div class="admin-form-group">
            <label class="admin-form-label" asp-for="CategoryEn"></label>
            <input class="admin-form-input" asp-for="CategoryEn" placeholder="Backend, Frontend, Database…" />
        </div>
    </div>
    <div class="admin-form-group">
        <label class="admin-form-label" asp-for="DescriptionEn"></label>
        <input class="admin-form-input" asp-for="DescriptionEn" />
    </div>

    <h3 class="admin-form-section">Persian (optional)</h3>
    <div class="admin-form-row">
        <div class="admin-form-group">
            <label class="admin-form-label" asp-for="NameFa"></label>
            <input class="admin-form-input admin-form-input--rtl" asp-for="NameFa" dir="rtl" />
        </div>
        <div class="admin-form-group">
            <label class="admin-form-label" asp-for="CategoryFa"></label>
            <input class="admin-form-input admin-form-input--rtl" asp-for="CategoryFa" dir="rtl" />
        </div>
    </div>
    <div class="admin-form-group">
        <label class="admin-form-label" asp-for="DescriptionFa"></label>
        <input class="admin-form-input admin-form-input--rtl" asp-for="DescriptionFa" dir="rtl" />
    </div>

    @if (isEdit)
    {
        <div class="admin-form-checks">
            <label class="admin-check"><input type="checkbox" asp-for="IsActive" /> <span>@Html.DisplayNameFor(m => m.IsActive)</span></label>
        </div>
    }

    <div class="admin-form-actions">
        <a asp-controller="Admin" asp-action="Skills" class="admin-btn admin-btn--ghost">Cancel</a>
        <button type="submit" class="admin-btn admin-btn--primary">@(isEdit ? "Save changes" : "Create skill")</button>
    </div>
</form>

@section Scripts {
    <script>
        (function () { "use strict"; AdminSidebar.init("skills"); if (window.lucide) lucide.createIcons(); })();
    </script>
}
