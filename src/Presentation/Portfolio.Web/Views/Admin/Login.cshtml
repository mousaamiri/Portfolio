@model Portfolio.Web.Models.AdminLoginModel
@{
    Layout = "_AdminAuthLayout";
    ViewData["Title"] = "Login";
    ViewData["AdminTitle"] = "Login";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin/login.css" />
}

@* ADMIN LOGIN (Phase 3) — real, server-side authentication. Posts to
   AdminController.Login, which forwards credentials to Portfolio.API and, on
   success, signs in an encrypted auth cookie holding the JWT. No client-side
   admin/admin gate. *@
<section class="login-section">
    <div class="login-bg-gradient" aria-hidden="true"></div>

    <div class="login-card">
        <div class="login-logo">
            <img id="loginLogo" src="~/images/logo-en-dark.svg" alt="Logo" class="login-logo-img" />
        </div>

        <h1 class="login-title">Admin Panel</h1>
        <p class="login-subtitle">Sign in to manage your portfolio</p>

        <form class="login-form" asp-controller="Admin" asp-action="Login" method="post" novalidate>
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

            <div class="login-form-group">
                <label class="login-form-label" for="Username">USERNAME</label>
                <div class="login-input-wrap">
                    <svg class="login-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                        <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/>
                        <circle cx="12" cy="7" r="4"/>
                    </svg>
                    <input asp-for="Username" id="Username" class="login-input" placeholder="Enter username" autocomplete="username" />
                </div>
                <span class="login-error" asp-validation-for="Username" aria-live="polite"></span>
            </div>

            <div class="login-form-group">
                <label class="login-form-label" for="Password">PASSWORD</label>
                <div class="login-input-wrap">
                    <svg class="login-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                        <rect width="18" height="11" x="3" y="11" rx="2" ry="2"/>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                    <input asp-for="Password" id="Password" type="password" class="login-input login-input--password" placeholder="Enter password" autocomplete="current-password" />
                    <button type="button" class="login-toggle-password" id="togglePassword" aria-label="Show password">
                        <svg class="icon-eye" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                            <path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"/>
                            <circle cx="12" cy="12" r="3"/>
                        </svg>
                        <svg class="icon-eye-off" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                            <path d="M10.733 5.076a10.744 10.744 0 0 1 11.205 6.575 1 1 0 0 1 0 .696 10.747 10.747 0 0 1-1.444 2.49"/>
                            <path d="M14.084 14.158a3 3 0 0 1-4.242-4.242"/>
                            <path d="M17.479 17.499a10.75 10.75 0 0 1-15.417-5.151 1 1 0 0 1 0-.696 10.75 10.75 0 0 1 4.446-5.143"/>
                            <path d="m2 2 20 20"/>
                        </svg>
                    </button>
                </div>
                <span class="login-error" asp-validation-for="Password" aria-live="polite"></span>
            </div>

            <div class="login-options">
                <label class="login-checkbox-label">
                    <input asp-for="RememberMe" class="login-checkbox" />
                    <span class="login-checkbox-custom"></span>
                    <span>Remember me</span>
                </label>
                <a asp-controller="Admin" asp-action="ForgotPassword" class="login-forgot-link">Forgot password?</a>
            </div>

            <button type="submit" class="login-submit-btn" id="loginSubmitBtn">
                <span class="login-submit-text">Sign In</span>
                <span class="login-submit-arrow">&rarr;</span>
            </button>

            @{ var formErrors = ViewData.ModelState[string.Empty]?.Errors; }
            @if (formErrors is { Count: > 0 })
            {
                <div class="login-form-feedback error" aria-live="polite">
                    @foreach (var e in formErrors)
                    {
                        <span>@e.ErrorMessage</span>
                    }
                </div>
            }
        </form>
    </div>
</section>

@section Scripts {
    <script>
        (function () {
            "use strict";
            // Theme-aware logo + password visibility toggle (cosmetic only).
            var logoImg = document.getElementById("loginLogo");
            function updateLogo() {
                if (!logoImg) return;
                var theme = document.documentElement.getAttribute("data-theme") || "dark";
                logoImg.src = "/images/logo-en-" + (theme === "light" ? "light" : "dark") + ".svg";
            }
            updateLogo();
            new MutationObserver(function (muts) {
                muts.forEach(function (m) { if (m.attributeName === "data-theme") updateLogo(); });
            }).observe(document.documentElement, { attributes: true });

            var toggleBtn = document.getElementById("togglePassword");
            var passwordInput = document.getElementById("Password");
            if (toggleBtn && passwordInput) {
                toggleBtn.addEventListener("click", function () {
                    var isPassword = passwordInput.type === "password";
                    passwordInput.type = isPassword ? "text" : "password";
                    toggleBtn.classList.toggle("active", isPassword);
                });
            }
        })();
    </script>
}
