@{
    Layout = "_AdminAuthLayout";
    ViewData["Title"] = "Login";
    ViewData["AdminTitle"] = "Login";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin/login.css" />
}

@* ADMIN LOGIN — INSECURE DEMO GATE (addendum). Checks admin/admin in plain JS
   and sets sessionStorage["admin_auth"]="1". This is NOT real authentication /
   authorization — anyone can bypass it via dev tools. Ported exactly as-is per
   the no-backend constraint; the visible "Demo credentials: admin / admin" hint
   makes the demo-only nature explicit. Separate from the public Login (Step 9). *@
<section class="login-section">
    <div class="login-bg-gradient" aria-hidden="true"></div>

    <div class="login-card">
        <div class="login-logo">
            <img id="loginLogo" src="~/images/logo-en-dark.svg" alt="Logo" class="login-logo-img" />
        </div>

        <h1 class="login-title">Admin Panel</h1>
        <p class="login-subtitle">Sign in to manage your portfolio</p>

        <form class="login-form" id="loginForm" novalidate>
            <div class="login-form-group" id="usernameGroup">
                <label class="login-form-label" for="loginUsername">USERNAME</label>
                <div class="login-input-wrap">
                    <svg class="login-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                        <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/>
                        <circle cx="12" cy="7" r="4"/>
                    </svg>
                    <input type="text" id="loginUsername" name="username" class="login-input" placeholder="Enter username" required autocomplete="username" />
                </div>
                <span class="login-error" id="usernameError" aria-live="polite"></span>
            </div>

            <div class="login-form-group" id="passwordGroup">
                <label class="login-form-label" for="loginPassword">PASSWORD</label>
                <div class="login-input-wrap">
                    <svg class="login-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                        <rect width="18" height="11" x="3" y="11" rx="2" ry="2"/>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                    <input type="password" id="loginPassword" name="password" class="login-input login-input--password" placeholder="Enter password" required autocomplete="current-password" />
                    <button type="button" class="login-toggle-password" id="togglePassword" aria-label="Show password">
                        <svg class="icon-eye" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                            <path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"/>
                            <circle cx="12" cy="12" r="3"/>
                        </svg>
                        <svg class="icon-eye-off" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                            <path d="M10.733 5.076a10.744 10.744 0 0 1 11.205 6.575 1 1 0 0 1 0 .696 10.747 10.747 0 0 1-1.444 2.49"/>
                            <path d="M14.084 14.158a3 3 0 0 1-4.242-4.242"/>
                            <path d="M17.479 17.499a10.75 10.75 0 0 1-15.417-5.151 1 1 0 0 1 0-.696 10.75 10.75 0 0 1 4.446-5.143"/>
                            <path d="m2 2 20 20"/>
                        </svg>
                    </button>
                </div>
                <span class="login-error" id="passwordError" aria-live="polite"></span>
            </div>

            <div class="login-demo-hint">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
                    <circle cx="12" cy="12" r="10"/>
                    <path d="M12 16v-4"/>
                    <path d="M12 8h.01"/>
                </svg>
                <span>Demo credentials: <strong>admin</strong> / <strong>admin</strong></span>
            </div>

            <div class="login-options">
                <label class="login-checkbox-label">
                    <input type="checkbox" id="rememberMe" class="login-checkbox" />
                    <span class="login-checkbox-custom"></span>
                    <span>Remember me</span>
                </label>
                <a asp-controller="Admin" asp-action="ForgotPassword" class="login-forgot-link">Forgot password?</a>
            </div>

            <button type="submit" class="login-submit-btn" id="loginSubmitBtn">
                <span class="login-submit-text">Sign In</span>
                <span class="login-submit-spinner" aria-hidden="true"></span>
                <span class="login-submit-arrow">&rarr;</span>
            </button>

            <div class="login-form-feedback" id="loginFeedback" aria-live="polite"></div>
        </form>
    </div>
</section>

@section Scripts {
    <script>
        (function () {
            "use strict";
            // Already logged in → go to dashboard.
            try { if (sessionStorage.getItem("admin_auth") === "1") { window.location.replace("/Admin"); return; } } catch (e) {}

            var form = document.getElementById("loginForm");
            var usernameInput = document.getElementById("loginUsername");
            var passwordInput = document.getElementById("loginPassword");
            var toggleBtn = document.getElementById("togglePassword");
            var submitBtn = document.getElementById("loginSubmitBtn");
            var feedback = document.getElementById("loginFeedback");
            var card = document.querySelector(".login-card");
            var logoImg = document.getElementById("loginLogo");

            function updateLogo() {
                if (!logoImg) return;
                var theme = document.documentElement.getAttribute("data-theme") || "dark";
                logoImg.src = "/images/logo-en-" + (theme === "light" ? "light" : "dark") + ".svg";
            }
            updateLogo();
            new MutationObserver(function (muts) {
                muts.forEach(function (m) { if (m.attributeName === "data-theme") updateLogo(); });
            }).observe(document.documentElement, { attributes: true });

            if (!form) return;

            if (toggleBtn && passwordInput) {
                toggleBtn.addEventListener("click", function () {
                    var isPassword = passwordInput.type === "password";
                    passwordInput.type = isPassword ? "text" : "password";
                    toggleBtn.classList.toggle("active", isPassword);
                });
            }

            function showFieldError(groupId, errorId, message) {
                var group = document.getElementById(groupId);
                var error = document.getElementById(errorId);
                if (group) group.classList.toggle("has-error", !!message);
                if (error) error.textContent = message || "";
            }

            function clearErrors() {
                showFieldError("usernameGroup", "usernameError", "");
                showFieldError("passwordGroup", "passwordError", "");
                if (feedback) { feedback.textContent = ""; feedback.className = "login-form-feedback"; }
            }

            if (usernameInput) usernameInput.addEventListener("input", function () { showFieldError("usernameGroup", "usernameError", ""); });
            if (passwordInput) passwordInput.addEventListener("input", function () { showFieldError("passwordGroup", "passwordError", ""); });

            form.addEventListener("submit", function (e) {
                e.preventDefault();
                clearErrors();

                var username = usernameInput ? usernameInput.value.trim() : "";
                var password = passwordInput ? passwordInput.value : "";

                var usernameErr = !username ? "Username is required" : "";
                var passwordErr = !password ? "Password is required" : "";

                if (usernameErr || passwordErr) {
                    showFieldError("usernameGroup", "usernameError", usernameErr);
                    showFieldError("passwordGroup", "passwordError", passwordErr);
                    if (card) { card.classList.remove("shake"); void card.offsetWidth; card.classList.add("shake"); }
                    return;
                }

                submitBtn.disabled = true;
                submitBtn.classList.add("loading");

                setTimeout(function () {
                    // INSECURE DEMO GATE — plain-text admin/admin check, no backend.
                    if (username === "admin" && password === "admin") {
                        try { sessionStorage.setItem("admin_auth", "1"); } catch (e) {}
                        if (feedback) { feedback.textContent = "Login successful! Redirecting..."; feedback.className = "login-form-feedback success"; }
                        setTimeout(function () { window.location.href = "/Admin"; }, 600);
                    } else {
                        submitBtn.disabled = false;
                        submitBtn.classList.remove("loading");
                        if (feedback) { feedback.textContent = "Invalid credentials. Try admin / admin"; feedback.className = "login-form-feedback error"; }
                        if (card) { card.classList.remove("shake"); void card.offsetWidth; card.classList.add("shake"); }
                    }
                }, 1000);
            });
        })();
    </script>
}
