@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Admin — Skills";
    ViewData["AdminTitle"] = "Skills";
}

@section Scripts {
    <script>
        (function () {
            "use strict";
            try { if (sessionStorage.getItem("admin_auth") !== "1") { window.location.replace("/Admin/Login"); return; } } catch (e) {}
            AdminSidebar.init("skills");
            if (window.lucide) lucide.createIcons();

            AdminCRUD.init({
                entityName: "Skill",
                title: "Skills",
                subtitle: "Manage your skill set",
                store: AdminData.Skills,
                searchKeys: ["name_en", "name_fa", "category"],
                columns: [
                    {
                        label: "Name", key: "name_en",
                        render: function (s) {
                            return '<div><div style="font-weight:600">' + AdminUtil.escapeHtml(s.name_en) + '</div>' +
                                '<div class="admin-cell-sub">' + AdminUtil.escapeHtml(s.name_fa) + '</div></div>';
                        }
                    },
                    { label: "Category", key: "category" },
                    {
                        label: "Level", key: "level",
                        render: function (s) {
                            return '<div style="display:flex;align-items:center;gap:10px;min-width:120px">' +
                                '<div style="flex:1;height:6px;border-radius:3px;background:var(--border)">' +
                                '<div style="height:100%;width:' + s.level + '%;border-radius:3px;background:var(--accent)"></div></div>' +
                                '<span style="font-size:12px;color:var(--text-faint);min-width:32px">' + s.level + '%</span></div>';
                        }
                    }
                ],
                formFields: [
                    { key: "name", label: "Skill Name", bilingual: true, required: true, placeholder: "e.g. JavaScript" },
                    { type: "row", fields: [
                        { key: "category", label: "Category", type: "select", options: [
                            "Frontend", "Backend", "Tools", "Design", "Other"
                        ], defaultValue: "Frontend" },
                        { key: "level", label: "Level (%)", type: "number", min: 0, max: 100, placeholder: "0-100" }
                    ]}
                ]
            });
        })();
    </script>
}
