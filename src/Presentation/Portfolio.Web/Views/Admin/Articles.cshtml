@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Admin — Articles";
    ViewData["AdminTitle"] = "Articles";
}

@section Scripts {
    <script>
        (function () {
            "use strict";
            try { if (sessionStorage.getItem("admin_auth") !== "1") { window.location.replace("/Admin/Login"); return; } } catch (e) {}
            AdminSidebar.init("articles");
            if (window.lucide) lucide.createIcons();

            AdminCRUD.init({
                entityName: "Article",
                title: "Articles",
                subtitle: "Manage your blog posts",
                store: AdminData.Articles,
                searchKeys: ["title_en", "title_fa", "excerpt_en", "excerpt_fa", "category"],
                columns: [
                    {
                        label: "Title", key: "title_en",
                        render: function (a) {
                            return '<div><div style="font-weight:600">' + AdminUtil.escapeHtml(a.title_en) + '</div>' +
                                '<div class="admin-cell-sub">' + AdminUtil.escapeHtml(a.title_fa) + '</div></div>';
                        }
                    },
                    { label: "Category", key: "category" },
                    {
                        label: "Read Time", key: "readTime",
                        render: function (a) { return a.readTime + ' min'; }
                    },
                    {
                        label: "Status", key: "status",
                        render: function (a) {
                            var cls = a.status === "published" ? "admin-status--published" : "admin-status--draft";
                            var txt = a.status === "published" ? "Published" : "Draft";
                            return '<span class="admin-status ' + cls + '"><span class="admin-status-dot"></span>' + txt + '</span>';
                        }
                    }
                ],
                formFields: [
                    { key: "title", label: "Title", bilingual: true, required: true, placeholder: "Article title" },
                    { key: "excerpt", label: "Excerpt", bilingual: true, type: "textarea", rows: 2, placeholder: "Short summary" },
                    { key: "body", label: "Body", bilingual: true, type: "textarea", rows: 6, placeholder: "Article content" },
                    { type: "row", fields: [
                        { key: "category", label: "Category", placeholder: "e.g. CSS, JavaScript" },
                        { key: "readTime", label: "Read Time (min)", type: "number", min: 1, max: 120, placeholder: "8" }
                    ]},
                    { key: "tags", label: "Tags", type: "tags", placeholder: "Add tag and press Enter", hint: "Press Enter or comma to add" },
                    { type: "row", fields: [
                        { key: "publishDate", label: "Publish Date", type: "date" },
                        { key: "status", label: "Status", type: "select", options: [
                            { value: "published", label: "Published" },
                            { value: "draft", label: "Draft" }
                        ], defaultValue: "published" }
                    ]}
                ]
            });
        })();
    </script>
}
