@model Portfolio.Web.Models.Admin.TimelineFormModel
@{
    Layout = "_AdminLayout";
    var isEdit = Model.IsEdit;
    ViewData["Title"] = isEdit ? "Admin — Edit Timeline" : "Admin — New Timeline";
    ViewData["AdminTitle"] = isEdit ? "Edit Timeline Entry" : "New Timeline Entry";
    var action = isEdit ? "TimelineEdit" : "TimelineCreate";
}
<div class="admin-page-header">
    <div><h1 class="admin-page-title">@(isEdit ? "Edit Timeline Entry" : "New Timeline Entry")</h1>
        <p class="admin-page-subtitle">About-page journey milestone</p></div>
    <a asp-controller="Admin" asp-action="Timeline" class="admin-btn admin-btn--ghost">Back to list</a>
</div>
<form asp-controller="Admin" asp-action="@action" asp-route-id="@Model.Id" method="post" class="admin-form">
    <div asp-validation-summary="ModelOnly" class="admin-form-error"></div>
    @if (isEdit) { <input type="hidden" asp-for="Id" /> }

    <div class="admin-form-row">
        <div class="admin-form-group">
            <label class="admin-form-label" asp-for="Year"></label>
            <input class="admin-form-input" asp-for="Year" placeholder="2024" />
            <span class="admin-form-error" asp-validation-for="Year"></span>
        </div>
        <div class="admin-form-group">
            <label class="admin-form-label" asp-for="Icon"></label>
            <input class="admin-form-input" asp-for="Icon" placeholder="rocket, graduation-cap…" />
        </div>
        <div class="admin-form-group">
            <label class="admin-form-label" asp-for="DisplayOrder"></label>
            <input class="admin-form-input" asp-for="DisplayOrder" type="number" />
        </div>
    </div>

    <h3 class="admin-form-section">English</h3>
    <div class="admin-form-group">
        <label class="admin-form-label" asp-for="TitleEn"></label>
        <input class="admin-form-input" asp-for="TitleEn" />
        <span class="admin-form-error" asp-validation-for="TitleEn"></span>
    </div>
    <div class="admin-form-group">
        <label class="admin-form-label" asp-for="DescriptionEn"></label>
        <textarea class="admin-form-textarea" asp-for="DescriptionEn" rows="2"></textarea>
    </div>
    <h3 class="admin-form-section">Persian (optional)</h3>
    <div class="admin-form-group">
        <label class="admin-form-label" asp-for="TitleFa"></label>
        <input class="admin-form-input admin-form-input--rtl" asp-for="TitleFa" dir="rtl" />
    </div>
    <div class="admin-form-group">
        <label class="admin-form-label" asp-for="DescriptionFa"></label>
        <textarea class="admin-form-textarea admin-form-input--rtl" asp-for="DescriptionFa" dir="rtl" rows="2"></textarea>
    </div>

    @if (isEdit)
    {
        <div class="admin-form-checks">
            <label class="admin-check"><input type="checkbox" asp-for="IsActive" /> <span>@Html.DisplayNameFor(m => m.IsActive)</span></label>
        </div>
    }
    <div class="admin-form-actions">
        <a asp-controller="Admin" asp-action="Timeline" class="admin-btn admin-btn--ghost">Cancel</a>
        <button type="submit" class="admin-btn admin-btn--primary">@(isEdit ? "Save changes" : "Create")</button>
    </div>
</form>
@section Scripts { <script>(function(){"use strict";AdminSidebar.init("timeline");if(window.lucide)lucide.createIcons();})();</script> }
