@model List<ProjectViewModel>
@{
    ViewData["Title"] = "Work";
    ViewData["I18nTitle"] = "work.title";
    ViewData["ActivePage"] = "work";

    // Shape the data exactly as work.js expects ({id, name, subtitle,
    // description, techs:[{name,color}], github}), per language.
    var projectsEn = Model.Select(p => new
    {
        id = p.DisplayId,
        name = p.NameEn,
        subtitle = p.SubtitleEn,
        description = p.DescriptionEn,
        techs = p.Techs.Select(t => new { name = t.Name, color = t.Color }),
        github = p.GithubUrl
    });
    var projectsFa = Model.Select(p => new
    {
        id = p.DisplayId,
        name = p.NameFa,
        subtitle = p.SubtitleFa,
        description = p.DescriptionFa,
        techs = p.Techs.Select(t => new { name = t.Name, color = t.Color }),
        github = p.GithubUrl
    });
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/work.css" />
}

@* ======================================================
   TODO: Work master/detail showcase — currently from MockDataService
   Model: List<ProjectViewModel> (bilingual + colored tech pills)
   Future: will be replaced by a real data source (out of scope for now)
   Note: Work is the one page whose source data is genuine parallel EN/FA arrays
   (not data-i18n). work.js switches on window.i18n.lang(). The initial list is
   server-rendered here for SEO/no-JS; work.js re-renders it identically and
   drives selection/detail-swap/modal/keyboard-nav (ported logic unchanged).
   ====================================================== *@
<section id="work" class="work-section">
    <div class="container">

        @* ===== SECTION 1: HEADER ===== *@
        <div class="about-eyebrow-row">
            <span class="eyebrow" data-i18n="work.eyebrow">WORK</span>
            <span class="eyebrow-rule" aria-hidden="true"></span>
        </div>
        <h2 class="work-heading" data-i18n="work.heading">SELECTED SYSTEMS &amp; ARCHITECTURE</h2>

        @* ===== SECTION 2: MASTER/DETAIL SHOWCASE ===== *@
        <div class="work-showcase">

            @* Left: Project list (server-rendered; work.js re-renders identically) *@
            <div class="work-list" role="tablist" aria-label="Project list">
                @for (var i = 0; i < Model.Count; i++)
                {
                    var p = Model[i];
                    var active = i == 0;
                    <button class="work-list-item@(active ? " is-active" : "")" role="tab" aria-selected="@(active ? "true" : "false")" data-index="@i">
                        <span class="work-list-number">@p.DisplayId.ToString("D2")</span>
                        <span class="work-list-text">
                            <span class="work-list-name">@p.NameEn</span>
                            <span class="work-list-sub">@p.SubtitleEn</span>
                        </span>
                    </button>
                }
            </div>

            @* Right: Detail panel (static shell; work.js populates text/pills/href) *@
            <div class="work-detail" role="tabpanel" aria-live="polite">
                <div class="work-detail-inner">
                    <span class="work-detail-number" id="detail-number">01</span>

                    <h3 class="work-detail-title" id="detail-title"></h3>
                    <p class="work-detail-subtitle" id="detail-subtitle"></p>

                    <div class="work-detail-preview" id="detail-preview">
                        <svg class="work-detail-preview-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/>
                            <polyline points="14 2 14 8 20 8"/>
                            <line x1="16" y1="13" x2="8" y2="13"/>
                            <line x1="16" y1="17" x2="8" y2="17"/>
                            <line x1="10" y1="9" x2="8" y2="9"/>
                        </svg>
                    </div>

                    <p class="work-detail-desc" id="detail-desc"></p>

                    <div class="work-detail-techs" id="detail-techs">
                        <!-- Tech pills rendered by JS -->
                    </div>

                    <a class="work-detail-github" id="detail-github" href="#" target="_blank" rel="noopener noreferrer">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                            <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                            <path d="M9 18c-4.51 2-5-2-7-2"/>
                        </svg>
                        <span data-i18n="work.view_github">View GitHub</span>
                    </a>
                </div>
            </div>
        </div>

        @* ===== MOBILE PROJECT MODAL ===== *@
        <div class="work-modal-overlay" id="work-modal-overlay">
            <div class="work-modal" role="dialog" aria-modal="true" aria-labelledby="modal-title">
                <button class="work-modal-close" id="work-modal-close" aria-label="Close">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
                        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                </button>
                <span class="work-modal-number" id="modal-number">01</span>
                <h3 class="work-modal-title" id="modal-title"></h3>
                <p class="work-modal-subtitle" id="modal-subtitle"></p>
                <p class="work-modal-desc" id="modal-desc"></p>
                <div class="work-modal-techs" id="modal-techs"></div>
                <a class="work-modal-github" id="modal-github" href="#" target="_blank" rel="noopener noreferrer">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                        <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                        <path d="M9 18c-4.51 2-5-2-7-2"/>
                    </svg>
                    <span data-i18n="work.view_github">View GitHub</span>
                </a>
            </div>
        </div>

    </div>

    @* ===== SECTION 3: CLOSING CTA (Work-specific — has a GitHub-stats card, so
         NOT the shared _ClosingCta partial) ===== *@
    <div class="closing-cta-block">
        <div class="closing-cta-eyebrow-row">
            <span class="eyebrow" data-i18n="cta.inner_mechanics">INNER MECHANICS</span>
        </div>
        <h2 class="closing-cta-heading">
            Where logic meets<br />
            <span class="script-gradient">rhythm.</span>
        </h2>

        <div class="closing-cta-grid">

            <div class="closing-cta-card">
                <div class="closing-cta-github-header">
                    <svg class="closing-cta-github-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                        <path d="M9 18c-4.51 2-5-2-7-2"/>
                    </svg>
                    <span class="closing-cta-github-name" data-i18n="cta.github_name">Mousa's Github</span>
                </div>
                <div class="closing-cta-latest-push">
                    <span class="closing-cta-latest-label" data-i18n="cta.latest_push">LATEST PUSH</span>
                    <span class="closing-cta-latest-badge" data-i18n="cta.ago">Recently</span>
                </div>
                <p class="closing-cta-commit-msg" data-i18n="cta.pushed_updates">Latest commits</p>
                <div class="closing-cta-commit-files">
                    <span class="closing-cta-file-badge">portfolio</span>
                </div>
                <div class="closing-cta-github-stats">
                    <div>
                        <span class="closing-cta-stat-number">3</span>
                        <span class="closing-cta-stat-label" data-i18n="cta.public_repos">PUBLIC REPOS</span>
                    </div>
                    <div>
                        <span class="closing-cta-stat-number">&mdash;</span>
                        <span class="closing-cta-stat-label" data-i18n="cta.followers">FOLLOWERS</span>
                    </div>
                </div>
                <div class="closing-cta-social-row">
                    <a href="https://github.com/mousaamiri" aria-label="GitHub">
                        <svg class="closing-cta-social-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                            <path d="M9 18c-4.51 2-5-2-7-2"/>
                        </svg>
                    </a>
                    <a href="#" aria-label="LinkedIn">
                        <svg class="closing-cta-social-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
                            <rect width="4" height="12" x="2" y="9"/>
                            <circle cx="4" cy="4" r="2"/>
                        </svg>
                    </a>
                    <a href="#" aria-label="X (Twitter)">
                        <svg class="closing-cta-social-icon" viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
                            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                        </svg>
                    </a>
                </div>
            </div>

            <div class="closing-cta-card">
                <span class="eyebrow eyebrow--sm" data-i18n="cta.writing">WRITING</span>
                <h4 class="closing-cta-card-title" data-i18n="cta.article_title">Clean Architecture in ASP.NET Core: Boundaries that Scale</h4>
                <span class="closing-cta-meta" data-i18n="cta.published_date">Draft</span>
                <a asp-controller="Blog" asp-action="Index" class="closing-cta-link">
                    <span data-i18n="cta.read_article">Read Article</span>
                    <span class="closing-cta-link-arrow">&rarr;</span>
                </a>
            </div>

            <div class="closing-cta-card">
                <span class="eyebrow eyebrow--sm" data-i18n="cta.workspace">WORKSPACE</span>
                <h4 class="closing-cta-card-title--large">
                    My daily<br />
                    <span class="script-gradient">drivers</span>
                </h4>
                <p class="closing-cta-card-desc" data-i18n="cta.gear_desc">A detailed list of the software and hardware I use every day.</p>
                <a href="#" class="closing-cta-link">
                    <span data-i18n="cta.view_gear">View Gear</span>
                    <span class="closing-cta-link-arrow">&rarr;</span>
                </a>
            </div>

        </div>
    </div>
</section>

@section PageScripts {
    @* Server-injected project data (single source of truth = MockDataService).
       work.js reads these globals via getActiveProjects(). *@
    <script>
        window.__workProjects = @Html.Raw(Json.Serialize(projectsEn));
        window.__workProjectsFa = @Html.Raw(Json.Serialize(projectsFa));
    </script>
    <script src="~/js/pages/work.js"></script>
}
